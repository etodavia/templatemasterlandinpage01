<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <%- include('partials/head-tags') %>
    <style>
        :root {
            --glass: rgba(255, 255, 255, 0.7);
            --glass-border: rgba(255, 255, 255, 0.4);
        }

        .about-section { padding: 120px 0; position: relative; }
        
        /* Modern Story Grid */
        .story-container {
            display: grid;
            grid-template-columns: 1.2fr 0.8fr;
            gap: 100px;
            align-items: flex-start;
        }
        
        .story-narrative h2 {
            font-size: 3rem; /* Reduzido de 4.2rem */
            line-height: 1.1;
            letter-spacing: -2px;
            color: var(--navy-blue);
            margin-bottom: 30px;
        }

        .story-narrative .lead-text {
            font-size: 1.25rem; /* Reduzido de 1.6rem */
            color: var(--accent-red);
            font-weight: 700;
            line-height: 1.4;
            margin-bottom: 30px;
            letter-spacing: 0;
        }

        .story-content {
            font-size: 1.1rem;
            color: #555;
            line-height: 1.7;
            column-count: 1;
        }
        .story-content p { margin-bottom: 25px; }

        /* Modern MVV */
        .mvv-modern-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-top: 60px;
        }

        .mvv-card-modern {
            background: white;
            padding: 60px 40px;
            border-radius: 30px;
            transition: all 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
            border: 1px solid rgba(0,0,0,0.03);
            position: relative;
            overflow: hidden;
        }

        .mvv-card-modern::before {
            content: '';
            position: absolute;
            top: 0; left: 0; width: 100%; height: 5px;
            background: var(--accent-red);
            transform: scaleX(0);
            transform-origin: left;
            transition: 0.6s;
        }

        .mvv-card-modern:hover {
            transform: translateY(-15px);
            box-shadow: 0 40px 80px rgba(10, 17, 40, 0.08);
            border-color: var(--accent-red);
        }

        .mvv-card-modern:hover::before { transform: scaleX(1); }

        .mvv-card-modern i {
            font-size: 3rem;
            color: var(--navy-blue);
            margin-bottom: 30px;
            display: block;
            opacity: 0.2;
        }

        .mvv-card-modern h3 {
            font-size: 1.4rem;
            text-transform: uppercase;
            letter-spacing: 3px;
            margin-bottom: 20px;
            font-weight: 800;
            color: var(--navy-blue);
        }

        /* Executive Team Section */
        .team-section-modern {
            background: var(--navy-blue);
            color: white;
            padding: 140px 0;
            border-radius: 80px 80px 0 0;
            margin-top: -40px;
            position: relative;
            z-index: 2;
        }

        .team-card-executive {
            position: relative;
            border-radius: 30px;
            overflow: hidden;
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.05);
            transition: 0.5s;
        }

        .team-card-executive:hover {
            background: rgba(255,255,255,0.08);
            transform: translateY(-10px);
        }

        .team-img-wrapper {
            width: 100%;
            height: 400px;
            overflow: hidden;
            filter: grayscale(1);
            transition: 0.8s;
            opacity: 0.7;
        }

        .team-card-executive:hover .team-img-wrapper {
            filter: grayscale(0);
            opacity: 1;
            transform: scale(1.05);
        }

        .team-info-box {
            padding: 30px;
            text-align: center;
        }

        .team-info-box h4 {
            font-size: 1.4rem;
            margin-bottom: 5px;
            letter-spacing: -1px;
        }

        .team-info-box span {
            font-size: 0.7rem;
            font-weight: 800;
            color: var(--accent-red);
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        @media (max-width: 1024px) {
            .story-container { grid-template-columns: 1fr; gap: 40px; }
            .story-narrative h2 { font-size: 3rem; }
            .mvv-modern-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body style="background: white;">
    <%- settings.custom_body_code || '' %>
    <%- include('partials/header') %>
    <%- include('partials/page-hero', { 
        pageTitle: settings.about_hero_title || 'Nossa <em>História</em>',
        image: settings.about_hero_image || 'https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&q=80&w=1600',
        imageTablet: settings.about_hero_image_tablet,
        imageMobile: settings.about_hero_image_mobile
    }) %>
    <main>
        <!-- MODERN STORY SECTION -->
        <section class="about-section">
            <div class="container">
                <div class="story-container">
                    <div class="story-narrative" data-reveal="left">
                        <span class="section-label">A Sistema</span>
                        <h2><%- settings.about_story_text_left || 'Engenharia de Gestão com <em>Alma Humana.</em>' %></h2>
                        <div class="lead-text">
                            <%= settings.about_story_lead || 'Transformamos processos rígidos em operações fluidas e ambientes de alto impacto.' %>
                        </div>
                    </div>
                    <div class="story-content" data-reveal="up">
                        <% if (settings.about_story_text_right) { %>
                            <% const paragraphs = settings.about_story_text_right.split('\n').filter(p => p.trim() !== ''); %>
                            <% paragraphs.forEach(p => { %>
                                <p><%= p %></p>
                            <% }); %>
                        <% } else { %>
                            <p>A Sua Empresa Δ nasceu da necessidade de humanizar a gestão sem perder o foco na lucratividade. Unimos dados e pessoas para criar operações fluidas e resilientes através de uma visão sistêmica.</p>
                            <p>Diferenciamos nossa atuação pela proximidade e pelo modelo boutique, onde cada estratégia é desenhada sob medida para as lacunas específicas do seu mercado e cultura interna.</p>
                            <p>Nossa jornada é marcada pela busca incessante da excelência técnica, transformando o capital humano em um motor de crescimento sustentável e governança sólida.</p>
                        <% } %>
                    </div>
                </div>
            </div>
        </section>

        <!-- MODERN GUIDELINES -->
        <section class="about-section" style="background: var(--bg-about); border-radius: 80px 80px 0 0;">
            <div class="container">
                <div style="text-align: center; margin-bottom: 80px;" data-reveal>
                    <span class="section-label" style="background: white;">DIRETRIZES</span>
                    <h2 style="font-size: 2.8rem; color: var(--navy-blue); letter-spacing: -2px; line-height: 1;"><%- settings.about_guidelines_title || 'DNA <em>Estratégico</em>' %></h2>
                    <p style="font-size: 1.1rem; color: #666; margin-top: 15px;"><%= settings.about_guidelines_text || 'O que nos move e define nossa entrega diária.' %></p>
                </div>
                
                <div class="mvv-modern-grid">
                    <div class="mvv-card-modern" data-reveal="up">
                        <i class="ri-rocket-2-line"></i>
                        <h3>Missão</h3>
                        <p><%= settings.about_mission || 'Impulsionar organizações através da gestão integrada de capital humano.' %></p>
                    </div>
                    <div class="mvv-card-modern" data-reveal="up" data-delay="0.1">
                        <i class="ri-eye-2-line"></i>
                        <h3>Visão</h3>
                        <p><%= settings.about_vision || 'Ser a consultoria boutique referência em transformações sistêmicas no Brasil.' %></p>
                    </div>
                    <div class="mvv-card-modern" data-reveal="up" data-delay="0.2">
                        <i class="ri-shield-flash-line"></i>
                        <h3>Valores</h3>
                        <p><%= settings.about_values || 'Excelência Técnica, Transparência Radical e Visão Sistêmica.' %></p>
                    </div>
                </div>
            </div>
        </section>

        <!-- EXECUTIVE TEAM -->
        <section class="team-section-modern">
            <div class="container">
                <div class="team-header" data-reveal="left" style="max-width: 700px;">
                    <span class="section-label" style="background: rgba(255,255,255,0.1); color: white; border: none;">SENIORITY</span>
                    <h2 style="font-size: 2.5rem; margin-top: 25px; letter-spacing: -1px;"><%- settings.about_team_title || 'Mentes que <em>Transformam</em>' %></h2>
                    <p style="font-size: 1.2rem; opacity: 0.6; margin-top: 25px; line-height: 1.6;">
                        <%= settings.about_team_text || 'Nosso time é composto por especialistas com décadas de experiência no chão de fábrica e em conselhos administrativos.' %>
                    </p>
                </div>
                
                <div class="services-grid" style="margin-top: 80px; grid-template-columns: repeat(3, 1fr); gap: 30px;">
                    <% team.forEach((member, index) => { %>
                        <div class="team-card-executive" data-reveal="up" data-delay="<%= index * 0.1 %>">
                            <div class="team-img-wrapper">
                                <img src="<%= member.imagem || '/kelly.png' %>" alt="<%= member.nome %> - <%= member.funcao %>" loading="lazy" decoding="async" style="width: 100%; height: 100%; object-fit: cover;">
                            </div>
                            <div class="team-info-box">
                                <h4><%= member.nome %></h4>
                                <span><%= member.funcao %></span>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>
        </section>
    </main>

    <%- include('partials/footer') %>

    <script>
    document.addEventListener('DOMContentLoaded', () => {
        if (!window.gsap || !window.ScrollTrigger) return;
        gsap.registerPlugin(ScrollTrigger);
        
        gsap.utils.toArray("[data-reveal]").forEach(el => {
            let config = {
                scrollTrigger: { trigger: el, start: "top 85%" },
                opacity: 0, duration: 1.5, ease: "expo.out"
            };
            
            const dir = el.getAttribute('data-reveal');
            if(dir === 'left') config.x = -80;
            else if(dir === 'up') config.y = 80;
            else config.y = 40;

            gsap.from(el, config);
        });
    });
    </script>
</body>
</html>
