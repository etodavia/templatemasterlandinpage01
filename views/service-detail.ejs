<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <%- include('partials/head-tags') %>
    <style>
        .article-content {
            font-size: 1.15rem;
            line-height: 1.85;
            color: #2d3436;
        }
        .article-content p { margin-bottom: 25px; }
        .article-content h2, .article-content h3 { 
            color: var(--navy-blue); 
            margin-top: 45px; 
            margin-bottom: 20px;
            font-weight: 800;
        }
        .article-content img {
            max-width: 100%;
            height: auto;
            border-radius: 20px;
            margin: 40px 0;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
        }

        /* Redes Sociais Flutuantes - Mobile Friendly */
        .hero-social-float {
            position: absolute;
            left: 3%;
            bottom: 60px;
            display: flex;
            flex-direction: column;
            gap: 12px;
            z-index: 10;
        }
        .hero-social-float a {
            width: 40px;
            height: 40px;
            background: white;
            color: var(--navy-blue);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            font-size: 1.1rem;
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
            transition: 0.3s;
        }
        .hero-social-float a:hover {
            background: var(--accent-red);
            color: white;
            transform: translateY(-5px);
        }

        .service-layout-grid {
            display: grid;
            grid-template-columns: 1fr 380px;
            gap: 80px;
        }

        .service-aside {
            position: sticky;
            top: 120px;
            height: fit-content;
        }

        .action-card {
            background: var(--navy-blue);
            color: white;
            padding: 40px;
            border-radius: 24px;
            box-shadow: 0 20px 40px rgba(10,17,40,0.15);
        }

        .feature-list {
            list-style: none;
            padding: 0;
            margin: 30px 0;
        }
        .feature-list li {
            padding: 15px 0;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 0.9rem;
            font-weight: 600;
        }
        .feature-list i { color: var(--accent-red); font-size: 1.2rem; }

        @media (max-width: 1024px) {
            .service-layout-grid { grid-template-columns: 1fr; gap: 60px; }
            .service-aside { position: relative; top: 0; }
            .hero-social-float {
                left: 15px;
                bottom: 40px;
                gap: 10px;
            }
            .hero-social-float a {
                width: 34px;
                height: 34px;
                font-size: 0.9rem;
            }
            .post-hero {
                padding-left: 65px !important;
                padding-bottom: 40px !important;
            }
        }
    </style>
</head>
<body style="background: #fafafa;">
    <%- settings.custom_body_code || '' %>
    <%- include('partials/header') %>

    <main>
        <!-- Hero Section -->
        <section class="post-hero" style="position: relative; height: 65vh; min-height: 480px; display: flex; align-items: flex-end; overflow: hidden; background: #000; padding-left: 10%; padding-bottom: 60px;">
            <img src="<%= service.imagem %>" alt="<%= service.titulo %>" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0.45;">
            <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(to top, rgba(10,17,40,0.95) 0%, rgba(10,17,40,0.3) 100%);"></div>
            
            <!-- Ícones Sociais Flutuantes -->
            <div class="hero-social-float">
                <a href="#"><i class="ri-facebook-fill"></i></a>
                <a href="#"><i class="ri-twitter-x-fill"></i></a>
                <a href="#"><i class="ri-linkedin-fill"></i></a>
                <a href="https://wa.me/<%= settings.whatsapp %>?text=<%= encodeURIComponent(settings.whatsapp_message || 'Olá, estive no site e gostaria de agendar uma consulta.') %>" class="btn-whatsapp-conversion"><i class="ri-whatsapp-line"></i></a>
            </div>

            <div class="container" style="position: relative; z-index: 2; margin: 0;">
                <div data-reveal="left">
                    <span class="badge" style="background: var(--accent-red); color: white; padding: 6px 18px; border-radius: 4px; font-weight: 800; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 25px; display: inline-block;">
                        Especialidade
                    </span>
                    <h1 style="color: white; font-size: clamp(2.5rem, 6vw, 4.8rem); font-weight: 800; line-height: 1; letter-spacing: -3px; max-width: 850px;">
                        <% if (service.titulo.includes('<em>')) { %>
                            <%- service.titulo %>
                        <% } else { %>
                            <% 
                                const words = service.titulo.split(' ');
                                if (words.length > 1) {
                                    const lastWord = words.pop();
                                    const rest = words.join(' ');
                            %>
                                <%= rest %> <em><%= lastWord %></em>
                            <% } else { %>
                                <%= service.titulo %>
                            <% } %>
                        <% } %>
                    </h1>
                </div>
            </div>
        </section>

        <section style="padding: 80px 0;">
            <div class="container">
                <div class="service-layout-grid">
                    
                    <!-- Coluna Principal -->
                    <div class="article-content" data-reveal="up">
                        <div style="background: #f8f8f6; border-left: 8px solid var(--accent-red); padding: 45px; border-radius: 20px; margin-bottom: 50px; box-shadow: 0 10px 30px rgba(0,0,0,0.03);">
                            <p style="margin-bottom: 0; font-size: 1.3rem; font-weight: 700; color: var(--navy-blue); line-height: 1.6;">
                                <%= service.resumo %>
                            </p>
                        </div>

                        <div class="content-body">
                            <%- service.conteudo %>
                            
                            <h3>Nossa Abordagem <em>Diferenciada</em></h3>
                            <p>
                                Na Sistema, não entregamos apenas consultoria técnica. Nossa metodologia para <strong><%= service.titulo %></strong> baseia-se em uma visão sistêmica que conecta o capital humano aos resultados financeiros da operação.
                            </p>
                            <p>
                                Mapeamos gargalos invisíveis, treinamos lideranças para a alta performance e redesenhamos fluxos estratégicos para que sua empresa opere em sua máxima potência competitiva.
                            </p>
                        </div>

                        <!-- Caixa de Utilidade (PDF) -->
                        <div style="background: #f4f4f2; padding: 40px; border-radius: 30px; display: flex; align-items: center; justify-content: space-between; margin-top: 60px;" class="no-print">
                            <div>
                                <span style="font-size: 0.75rem; font-weight: 800; letter-spacing: 1px; color: var(--navy-blue); display: block; margin-bottom: 12px;">UTILIDADE:</span>
                                <button onclick="window.print()" style="background: var(--navy-blue); color: white; border: none; padding: 18px 35px; border-radius: 50px; font-weight: 800; display: flex; align-items: center; gap: 12px; cursor: pointer;">
                                    <i class="ri-printer-line"></i> IMPRIMIR ESCOPO
                                </button>
                            </div>
                            <a href="/servicos" style="text-decoration: none; color: var(--navy-blue); font-weight: 800; display: flex; align-items: center; gap: 10px; font-size: 0.95rem;">
                                <i class="ri-arrow-left-line"></i> TODAS AS ESPECIALIDADES
                            </a>
                        </div>
                    </div>

                    <!-- Sidebar -->
                    <aside class="service-aside no-print" data-reveal="right">
                        <div class="action-card">
                            <h4 style="font-weight: 800; font-size: 1.6rem; margin-bottom: 15px;">Fale com um <br><em>Estrategista.</em></h4>
                            <p style="margin-bottom: 30px; line-height: 1.5; color: rgba(255,255,255,0.7);">Estamos prontos para entender seu cenário e propor soluções sob medida para sua gestão.</p>
                            
                            <a href="https://wa.me/<%= settings.whatsapp %>?text=<%= encodeURIComponent(settings.whatsapp_message || 'Olá, estive no site e gostaria de agendar uma consulta.') %>" class="btn-whatsapp-conversion" style="background: white; color: var(--navy-blue); display: flex; align-items: center; justify-content: center; gap: 10px; padding: 18px; border-radius: 12px; text-decoration: none; font-weight: 800; transition: 0.3s;">
                                <i class="ri-whatsapp-line"></i> WHATSAPP DIRETO
                            </a>

                            <ul class="feature-list">
                                <li><i class="ri-checkbox-circle-fill"></i> Atendimento Senior</li>
                                <li><i class="ri-checkbox-circle-fill"></i> Diagnóstico Ágil</li>
                                <li><i class="ri-checkbox-circle-fill"></i> Foco em ROI</li>
                            </ul>
                        </div>
                    </aside>

                </div>
            </div>
        </section>
    </main>

    <%- include('partials/footer') %>

    <script>
    document.addEventListener('DOMContentLoaded', () => {
        if (!window.gsap || !window.ScrollTrigger) return;
        gsap.registerPlugin(ScrollTrigger);
        gsap.utils.toArray("[data-reveal]").forEach(el => {
            gsap.from(el, {
                scrollTrigger: { trigger: el, start: "top 85%", toggleActions: "play none none none" },
                opacity: 0,
                y: 30,
                x: el.getAttribute('data-reveal') === 'right' ? 50 : (el.getAttribute('data-reveal') === 'left' ? -50 : 0),
                duration: 1,
                ease: "power2.out"
            });
        });
    });
    </script>
</body>
</html>
