<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <%- include('partials/head-tags') %>
    <style>
        .article-body {
            font-size: 1.15rem;
            line-height: 1.7;
            color: var(--text-dark);
        }
        .article-body p { margin-bottom: 25px; }
        
        /* Redes Sociais Flutuantes - Agora Visíveis em Mobile */
        .hero-social-float {
            position: absolute;
            left: 3%;
            bottom: 60px;
            display: flex;
            flex-direction: column;
            gap: 12px;
            z-index: 10;
        }
        .hero-social-float a {
            width: 40px;
            height: 40px;
            background: white;
            color: var(--navy-blue);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            font-size: 1.1rem;
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
            transition: 0.3s;
        }
        .hero-social-float a:hover {
            background: var(--accent-red);
            color: white;
            transform: translateY(-5px);
        }

        .utility-box {
            background: #f4f4f2;
            padding: 40px;
            border-radius: 30px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-top: 60px;
        }

        .discussion-section {
            margin-top: 100px;
            padding-top: 60px;
            border-top: 1px solid #eee;
        }

        .form-card {
            background: #f8f8f6;
            padding: 50px;
            border-radius: 40px;
            margin-top: 40px;
        }

        .form-label {
            font-size: 0.75rem;
            font-weight: 800;
            letter-spacing: 1px;
            color: var(--navy-blue);
            display: block;
            margin-bottom: 12px;
        }

        .form-input {
            width: 100%;
            padding: 18px 25px;
            border-radius: 15px;
            border: 1px solid rgba(0,0,0,0.05);
            background: white;
            outline: none;
            font-family: var(--font-main);
            transition: 0.3s;
        }

        .form-input:focus {
            border-color: var(--accent-red);
        }

        @media (max-width: 768px) {
            .hero-social-float {
                left: 15px;
                bottom: 40px;
                gap: 10px;
            }
            .hero-social-float a {
                width: 34px;
                height: 34px;
                font-size: 0.9rem;
                border-radius: 8px;
            }
            .post-hero {
                padding-left: 65px !important; /* Abre espaço para os ícones no mobile */
                padding-bottom: 40px !important;
            }
            .utility-box { flex-direction: column; gap: 30px; text-align: center; }
            .discussion-form { grid-template-columns: 1fr !important; }
            .discussion-section h2 { font-size: 2.2rem !important; }
        }
    </style>
</head>
<body style="background: #ffffff;">
    <%- settings.custom_body_code || '' %>
    <%- include('partials/header') %>

    <main>
        <!-- Hero Section -->
        <section class="post-hero" style="position: relative; height: 60vh; min-height: 450px; display: flex; align-items: flex-end; overflow: hidden; background: #000; padding-left: 10%; padding-bottom: 60px;">
            <img src="<%= post.imagem %>" alt="<%= post.titulo %>" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0.4;">
            <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(to top, rgba(10,17,40,0.95) 0%, rgba(10,17,40,0.4) 100%);"></div>
            
            <!-- Ícones Sociais Flutuantes -->
            <div class="hero-social-float">
                <a href="#"><i class="ri-facebook-fill"></i></a>
                <a href="#"><i class="ri-twitter-x-fill"></i></a>
                <a href="#"><i class="ri-linkedin-fill"></i></a>
                <a href="https://wa.me/<%= settings.whatsapp %>" class="btn-whatsapp-conversion"><i class="ri-whatsapp-line"></i></a>
            </div>

            <div class="container" style="position: relative; z-index: 2; margin: 0;">
                <div data-reveal="left">
                    <span class="badge" style="background: var(--accent-red); color: white; padding: 6px 18px; border-radius: 4px; font-weight: 800; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 25px; display: inline-block;">
                        <%= post.categoria %>
                    </span>
                    <h1 style="color: white; font-size: clamp(2.5rem, 6vw, 4.8rem); font-weight: 800; line-height: 1; letter-spacing: -3px; max-width: 900px;">
                        <% if (post.titulo.includes('<em>')) { %>
                            <%- post.titulo %>
                        <% } else { %>
                            <% 
                                const words = post.titulo.split(' ');
                                if (words.length > 1) {
                                    const lastWord = words.pop();
                                    const rest = words.join(' ');
                            %>
                                <%= rest %> <em><%= lastWord %></em>
                            <% } else { %>
                                <%= post.titulo %>
                            <% } %>
                        <% } %>
                    </h1>
                    <div style="margin-top: 35px; color: rgba(255,255,255,0.6); font-weight: 600; display: flex; align-items: center; gap: 25px; font-size: 0.9rem;">
                        <span><i class="ri-calendar-line" style="color: var(--accent-red);"></i> <%= post.data %></span>
                        <span><i class="ri-time-line" style="color: var(--accent-red);"></i> 5 min de leitura</span>
                    </div>
                </div>
            </div>
        </section>

        <section style="padding: 100px 0;">
            <div class="container">
                <div style="max-width: 900px; margin: 0 auto;">
                    
                    <!-- Resumo Card -->
                    <div style="background: #f8f8f6; border-left: 8px solid var(--accent-red); padding: 45px; border-radius: 20px; margin-bottom: 60px;" data-reveal="up">
                        <h3 style="font-size: 1.6rem; color: var(--navy-blue); line-height: 1.4; font-weight: 700; margin: 0;">
                            <%= post.resumo %>
                        </h3>
                    </div>

                    <!-- Conteúdo Principal -->
                    <article class="article-body" data-reveal="up">
                        <%- post.conteudo %>
                    </article>

                    <!-- Caixa de Utilidade (PDF) -->
                    <div class="utility-box no-print" data-reveal="up">
                        <div>
                            <span class="form-label">UTILIDADE:</span>
                            <button onclick="window.print()" style="background: var(--navy-blue); color: white; border: none; padding: 18px 35px; border-radius: 50px; font-weight: 800; display: flex; align-items: center; gap: 12px; cursor: pointer; transition: 0.3s;">
                                <i class="ri-printer-line"></i> GERAR PDF COLORIDO
                            </button>
                        </div>
                        <a href="/blog" style="text-decoration: none; color: var(--navy-blue); font-weight: 800; display: flex; align-items: center; gap: 10px; font-size: 0.95rem;">
                            <i class="ri-arrow-left-line"></i> VOLTAR AO LISTADO
                        </a>
                    </div>

                    <!-- Seção de Discussão -->
                    <section class="discussion-section no-print" data-reveal="up">
                        <h2 style="font-size: 3.5rem; color: var(--navy-blue); letter-spacing: -2px; font-weight: 800;">
                            Discussão & <em>Interação</em>
                        </h2>
                        <p style="color: #888; font-style: italic; margin-top: 10px; font-size: 1.1rem;">
                            Seja o primeiro a comentar sobre este artigo.
                        </p>

                        <div class="form-card">
                            <h4 style="font-size: 1.8rem; margin-bottom: 35px; color: var(--navy-blue); font-weight: 800;">Deixe sua opinião</h4>
                            <form action="/api/comentarios" method="POST" class="discussion-form" style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px;">
                                <input type="hidden" name="post_id" value="<%= post.id %>">
                                <div>
                                    <label class="form-label">NOME COMPLETO</label>
                                    <input type="text" name="nome" placeholder="Seu nome" required class="form-input">
                                </div>
                                <div>
                                    <label class="form-label">E-MAIL (PRIVADO)</label>
                                    <input type="email" name="email" placeholder="seu@email.com" required class="form-input">
                                </div>
                                <div style="grid-column: span 2;">
                                    <label class="form-label">COMENTÁRIO</label>
                                    <textarea name="comentario" placeholder="Escreva aqui sua percepção ou dúvida..." required class="form-input" style="height: 180px; resize: none;"></textarea>
                                </div>
                                <button type="submit" style="background: var(--navy-blue); color: white; border: none; padding: 20px; border-radius: 50px; font-weight: 800; cursor: pointer; grid-column: span 2; transition: 0.3s; letter-spacing: 1px;" onmouseover="this.style.background='var(--accent-red)'" onmouseout="this.style.background='var(--navy-blue)'">
                                    ENVIAR COMENTÁRIO
                                </button>
                            </form>
                        </div>
                    </section>

                </div>
            </div>
        </section>
    </main>

    <%- include('partials/footer') %>

    <script>
        gsap.registerPlugin(ScrollTrigger);
        gsap.utils.toArray("[data-reveal]").forEach(el => {
            gsap.from(el, {
                scrollTrigger: { trigger: el, start: "top 85%", toggleActions: "play none none none" },
                opacity: 0,
                y: 30,
                duration: 1,
                ease: "power2.out"
            });
        });
    </script>
</body>
</html>
