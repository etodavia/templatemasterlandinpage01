<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <%- include('partials/head-tags') %>
    <% 
        const oColor = settings.hero_overlay_color || '#0A1128';
        const oOpacity = settings.hero_overlay_opacity || 0.4;
        function hexToRgb(hex) {
            hex = hex.replace('#', '');
            const r = parseInt(hex.length === 3 ? hex[0]+hex[0] : hex.substring(0, 2), 16);
            const g = parseInt(hex.length === 3 ? hex[1]+hex[1] : hex.substring(2, 4), 16);
            const b = parseInt(hex.length === 3 ? hex[2]+hex[2] : hex.substring(4, 6), 16);
            return `${r}, ${g}, ${b}`;
        }
        const overlayRgb = hexToRgb(oColor);
        const overlayStyle = `linear-gradient(rgba(${overlayRgb}, ${oOpacity}), rgba(${overlayRgb}, ${oOpacity}))`;
        const normalizeHeroImage = (src) => {
            const cleanSrc = String(src || '').trim().replace(/\\/g, '/');
            if (!cleanSrc) return '';
            const separator = cleanSrc.includes('?') ? '&' : '?';
            return `${cleanSrc}${separator}v=${locals.assetVersion || '1'}`;
        };
        const heroDesktop = normalizeHeroImage(settings.hero_image);
        const heroTablet = normalizeHeroImage(settings.hero_image_tablet || settings.hero_image);
        const heroMobile = normalizeHeroImage(settings.hero_image_mobile || settings.hero_image_tablet || settings.hero_image);
        const settingNumber = (value, fallback = 0) => {
            if (value === null || typeof value === 'undefined' || value === '') return Number(fallback || 0);
            return Number(value);
        };
        const heroTitleOffsetLegacy = settingNumber(settings.hero_title_offset_y, 0);
        const heroButtonOffsetLegacy = settingNumber(settings.hero_button_offset_y, 0);
        const heroTitleOffsetDesktop = settingNumber(settings.hero_title_offset_y_desktop, heroTitleOffsetLegacy);
        const heroTitleOffsetTablet = settingNumber(settings.hero_title_offset_y_tablet, heroTitleOffsetLegacy);
        const heroTitleOffsetMobile = settingNumber(settings.hero_title_offset_y_mobile, heroTitleOffsetLegacy);
        const heroButtonOffsetDesktop = settingNumber(settings.hero_button_offset_y_desktop, heroButtonOffsetLegacy);
        const heroButtonOffsetTablet = settingNumber(settings.hero_button_offset_y_tablet, heroButtonOffsetLegacy);
        const heroButtonOffsetMobile = settingNumber(settings.hero_button_offset_y_mobile, heroButtonOffsetLegacy);
        const heroText = (value, fallback) => (value === null || typeof value === 'undefined') ? fallback : String(value);
        const homeHeroTitle = heroText(settings.home_hero_title, 'Lidere Negócios com <em>Confiança</em>.');
        const homeHeroDescription = heroText(settings.home_hero_description, 'Consultoria estratégica especializada em impulsionar o capital humano e elevar a performance operacional.');
        const homeHeroButtonText = heroText(settings.home_hero_button_text, 'Agendar Consultoria');
        const homeHeroCardTitle = heroText(settings.home_hero_card_title, 'Sua empresa em <em>Crescimento</em>.');
        const homeHeroCardSubtitle = heroText(settings.home_hero_card_subtitle, 'Experiência Estratégica');
    %>
    <% if (heroDesktop) { %>
        <link rel="preload"
              as="image"
              href="<%= heroDesktop %>"
              imagesrcset="<%= heroMobile || heroDesktop %> 640w, <%= heroTablet || heroDesktop %> 1024w, <%= heroDesktop %> 1600w"
              imagesizes="100vw"
              fetchpriority="high">
    <% } %>
    <style>
        .hero { 
            height: 85vh; 
            margin-top: 0 !important;
            border-top: none !important;
        }
    </style>
</head>
<body style="background: white; padding-top: 0 !important;">
    <%- settings.custom_body_code || '' %>
    <%- include('partials/header') %>

    <main>
        <!-- HERO IMPACTO -->
        <section id="home" class="hero" style="background: var(--navy-blue) !important; background-image: none !important; --responsive-bg-desktop: <%= overlayStyle %>, url('<%= heroDesktop %>'); --responsive-bg-tablet: <%= overlayStyle %>, url('<%= heroTablet %>'); --responsive-bg-mobile: <%= overlayStyle %>, url('<%= heroMobile %>'); --hero-title-offset-y-desktop: <%= heroTitleOffsetDesktop %>px; --hero-title-offset-y-tablet: <%= heroTitleOffsetTablet %>px; --hero-title-offset-y-mobile: <%= heroTitleOffsetMobile %>px; --hero-button-offset-y-desktop: <%= heroButtonOffsetDesktop %>px; --hero-button-offset-y-tablet: <%= heroButtonOffsetTablet %>px; --hero-button-offset-y-mobile: <%= heroButtonOffsetMobile %>px;">
            <% if (heroDesktop) { %>
                <picture class="hero-media">
                    <source media="(max-width: 640px)" srcset="<%= heroMobile || heroDesktop %>">
                    <source media="(max-width: 1024px)" srcset="<%= heroTablet || heroDesktop %>">
                    <img src="<%= heroDesktop %>" alt="" aria-hidden="true" loading="eager" decoding="sync" fetchpriority="high">
                </picture>
            <% } %>
            <div class="hero-overlay" style="background: rgba(<%= overlayRgb %>, <%= oOpacity %>);"></div>
            <div class="hero-content">
                <% if (homeHeroTitle.trim()) { %>
                    <h1 data-reveal class="hero-title-adjustable">
                        <%- homeHeroTitle %>
                    </h1>
                <% } %>
                <% if (homeHeroDescription.trim()) { %>
                    <p data-reveal>
                        <%- homeHeroDescription %>
                    </p>
                <% } %>
                <% if (homeHeroButtonText.trim()) { %>
                <div data-reveal class="hero-button-adjustable" style="display: flex; justify-content: flex-start;">
                    <a href="https://wa.me/<%= settings.whatsapp %>?text=<%= encodeURIComponent(settings.whatsapp_message || 'Olá, estive no site e gostaria de agendar uma consulta.') %>" class="btn-pill-large btn-whatsapp-conversion" style="width: auto !important; min-width: 200px; padding: 18px 30px; <%= settings.color_hero_button ? 'background:'+settings.color_hero_button+'; color: white;' : '' %>">
                        <%= homeHeroButtonText %> 
                        <div class="icon-blue-circle" style="<%= settings.color_hero_button ? 'background: rgba(255,255,255,0.2);' : 'background: var(--accent-red);' %> color: white;"><i class="ri-arrow-right-up-line"></i></div>
                    </a>
                </div>
                <% } %>
            </div>
            <% if (homeHeroCardTitle.trim() || homeHeroCardSubtitle.trim()) { %>
            <div class="floating-card" data-reveal style="bottom: 30px;">
                <% if (homeHeroCardTitle.trim()) { %><h4><%- homeHeroCardTitle %></h4><% } %>
                <% if (homeHeroCardSubtitle.trim()) { %><a href="/#servicos"><%= homeHeroCardSubtitle %> <i class="ri-arrow-right-line"></i></a><% } %>
            </div>
            <% } %>
        </section>

        <!-- SOBRE (DINÂMICO) -->
        <section id="sobre" style="background: var(--bg-about); padding: 100px 0;">
            <div class="container">
                <div class="about-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center;">
                    <div data-reveal="left">
                        <span class="section-label">NOSSA ESSÊNCIA</span>
                        <h2 style="font-size: 3.5rem; line-height: 1; letter-spacing: -3px; margin-bottom: 25px; color: var(--navy-blue);">
                            <%- settings.about_title || 'Sinergia Pura entre <em>Pessoas e Resultados</em>.' %>
                        </h2>
                        <p style="font-size: 1.2rem; color: var(--text-color); margin-bottom: 40px; line-height: 1.6;">
                            <%= settings.about_text || 'Na Arque Gestão, acreditamos que a cultura organizacional é o verdadeiro motor da inovação. Nossa abordagem sistêmica conecta os pontos invisíveis que transformam ambientes de trabalho em centros de excelência.' %>
                        </p>
                        <a href="/#servicos" class="btn-pill-large" style="background: var(--navy-blue); color: white;">
                            <%= settings.home_about_button_text || 'Conhecer nossos serviços' %> <div class="icon-blue-circle" style="background: white; color: var(--navy-blue);"><i class="ri-arrow-right-line"></i></div>
                        </a>
                    </div>
                    <div data-reveal="right" class="about-image-wrapper">
                        <img src="<%= settings.about_image || 'https://images.unsplash.com/photo-1543269865-cbf427effbad?auto=format&fit=crop&q=80&w=800' %>"
                             alt="Equipe da <%= settings.site_name || 'empresa' %> em atividade"
                             loading="lazy" decoding="async"
                             style="width: 100%; height: 550px; object-fit: cover; border-radius: 40px; box-shadow: 0 40px 100px rgba(0,0,0,0.1);">
                    </div>
                </div>
            </div>
        </section>

        <!-- SERVIÇOS -->
        <style>
            @media (max-width: 1024px) {
                .section-header-flex { flex-direction: column; align-items: flex-start !important; gap: 20px; }
            }
            .servicesSwiper { padding-bottom: 40px; }
            .servicesSwiper .swiper-slide { height: auto !important; }
        </style>
        <section id="servicos" style="background: var(--bg-sand); padding: 60px 0;">
            <div class="container">
                <div class="section-header-flex" style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 40px;">
                    <div data-reveal="left">
                        <span class="section-label">Especialidades</span>
                        <h2 style="font-size: 2.8rem; color: var(--navy-blue); line-height: 1.1; margin-bottom: 10px;">
                            <%- settings.services_section_title || 'Conheça nossos <em>Serviços</em>' %>
                        </h2>
                        <p style="color: var(--text-color); max-width: 500px;"><%= settings.services_section_text %></p>
                    </div>
                </div>
                <div class="swiper servicesSwiper" style="overflow: hidden;">
                    <div class="swiper-wrapper services-wrapper-mobile">
                        <% if (locals.services) { %>
                            <% locals.services.forEach(s => { %>
                                <div class="swiper-slide services-slide">
                                    <div style="background: var(--bg-header); border-radius: 20px; padding: 35px; box-shadow: 0 4px 20px rgba(0,0,0,0.03); height: 100%; display: flex; flex-direction: column;" data-reveal="up">
                                        <div style="width: 55px; height: 55px; background: rgba(0,0,0,0.03); border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-bottom: 20px;">
                                            <i class="<%= s.icone %>" style="font-size: 1.8rem; color: var(--navy-blue);"></i>
                                        </div>
                                        <h3 style="font-size: 1.4rem; margin-bottom: 15px; color: var(--navy-blue);"><%= s.titulo %></h3>
                                        <p style="color: var(--text-color); font-size: 0.9rem; line-height: 1.6; margin-bottom: auto;"><%= s.resumo %></p>
                                        <a href="https://wa.me/<%= settings.whatsapp ? settings.whatsapp.replace(/\D/g, '') : '' %>?text=Olá,%20tenho%20interesse%20no%20serviço%20<%= encodeURIComponent(s.titulo) %>" target="_blank" class="btn-whatsapp-conversion" style="margin-top: 15px; display: inline-flex; align-items: center; gap: 5px; color: var(--navy-blue); font-weight: 600; text-decoration: none; font-size: 0.9rem;">
                                            Estou interessado <i class="ri-whatsapp-line"></i>
                                        </a>
                                    </div>
                                </div>
                            <% }) %>
                        <% } %>
                    </div>
                    <div class="swiper-pagination services-pagination" style="position: relative; margin-top: 20px;"></div>
                </div>
            </div>
        </section>
        
        <!-- BENEFÍCIOS (CARROSSEL PREMIUM) -->
        <section id="beneficios" style="padding: 100px 0; background: <%= settings.benefits_color || 'white' %>; overflow: hidden;">
            <div class="container">
                <div class="section-header" style="text-align: center; margin-bottom: 60px;" data-reveal="up">
                    <span class="section-label">Vantagens</span>
                    <h2 style="font-size: 2.8rem; color: <%= settings.benefits_title_color || 'var(--navy-blue)' %>; line-height: 1.1; margin-top: 10px;">
                        <%- settings.benefits_title || 'Benefícios que <em>Transformam</em>' %>
                    </h2>
                    <% if (settings.benefits_text) { %>
                        <p style="color: <%= settings.benefits_text_color || '#64748b' %>; margin-top: 15px; max-width: 600px; margin-left: auto; margin-right: auto;"><%= settings.benefits_text %></p>
                    <% } %>
                </div>

                <div class="swiper beneficiosSwiper" style="padding: 20px 10px 50px 10px;">
                    <div class="swiper-wrapper">
                        <% if (locals.beneficios && beneficios.length > 0) { %>
                            <% beneficios.forEach(b => { %>
                                <div class="swiper-slide">
                                    <div class="beneficio-item" style="background: <%= settings.benefits_card_bg || 'rgba(255, 255, 255, 0.6)' %>; backdrop-filter: blur(10px); padding: 40px; border-radius: 24px; border: 1px solid rgba(0,0,0,0.05); transition: 0.3s; display: flex; flex-direction: column; gap: 20px; height: 100%;">
                                        <div class="beneficio-icon" style="width: 60px; height: 60px; background: <%= settings.benefits_icon_bg || 'white' %>; border-radius: 16px; display: flex; align-items: center; justify-content: center; font-size: 1.8rem; color: <%= settings.benefits_icon_color || 'var(--accent-red)' %>; box-shadow: 0 10px 20px rgba(0,0,0,0.02);">
                                            <i class="<%= b.icone %>"></i>
                                        </div>
                                        <h3 style="font-size: 1.25rem; font-weight: 800; color: <%= settings.benefits_card_title_color || 'var(--navy-blue)' %>; margin: 0;"><%= b.titulo %></h3>
                                        <p style="font-size: 0.95rem; line-height: 1.6; color: <%= settings.benefits_card_text_color || '#64748b' %>; margin: 0;"><%= b.texto %></p>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <div class="swiper-slide">
                                <div class="beneficio-item" style="background: #F8FAFC; padding: 40px; border-radius: 24px; text-align: center;">
                                    <p style="color: #94a3b8;">Cadastre os benefícios no painel administrativo.</p>
                                </div>
                            </div>
                        <% } %>
                    </div>
                    
                    <!-- Navegação -->
                    <div class="swiper-button-next" style="color: var(--navy-blue); transform: translateX(20px);"></div>
                    <div class="swiper-button-prev" style="color: var(--navy-blue); transform: translateX(-20px);"></div>
                    <div class="swiper-pagination beneficios-pagination"></div>
                </div>
            </div>
        </section>

        <style>
            .beneficio-item {
                cursor: grab;
                user-select: none;
            }
            .beneficio-item:active {
                cursor: grabbing;
            }
            .beneficio-item:hover {
                transform: translateY(-8px);
                box-shadow: 0 20px 40px rgba(0,0,0,0.08);
                border-color: var(--accent-red);
                background: white !important;
            }
            .beneficiosSwiper .swiper-pagination-bullet-active {
                background: var(--accent-red);
            }
            @media (max-width: 768px) {
                .swiper-button-next, .swiper-button-prev { display: none !important; }
            }
        </style>





        <!-- AVALIACOES / DEPOIMENTOS -->
        <section style="background: var(--bg-header); padding: 100px 0; overflow: hidden;">
            <div class="container">
                <div style="text-align: center; margin-bottom: 60px;" data-reveal>
                    <span class="section-label"><%= testimonialSource === 'google' ? 'Avaliações no Google' : 'Cases de Sucesso' %></span>
                    <h2 style="font-size: 3.2rem; color: var(--navy-blue);">
                        <%- settings.testimonial_section_title || 'O que dizem os <em>Clientes</em>' %>
                    </h2>
                </div>
                
                <div class="swiper testimonialsSwiper">
                    <div class="swiper-wrapper">
                        <% if (testimonials && testimonials.length > 0) { %>
                            <% testimonials.forEach(t => { %>
                                <div class="swiper-slide">
                                    <div style="background: var(--bg-sand); border-radius: 24px; padding: 35px; min-height: 250px; display: flex; flex-direction: column; justify-content: space-between;">
                                        <div>
                                            <div style="display: flex; align-items: center; gap: 15px; margin-bottom: 18px;">
                                                <img src="<%= t.foto || 'https://images.unsplash.com/photo-1633332755192-727a05c4013d?auto=format&fit=crop&q=80&w=100' %>"
                                                     alt="Foto de <%= t.nome || 'cliente' %>" loading="lazy" decoding="async"
                                                     onerror="this.onerror=null;this.src='/img/placeholder-user.svg';"
                                                     style="width: 60px; height: 60px; border-radius: 50%; object-fit: cover;">
                                                <div>
                                                    <div style="font-weight: 800; color: var(--navy-blue); font-size: 0.95rem;"><%= t.nome %></div>
                                                    <% if (t.origem === 'google') { %>
                                                        <div style="font-size: 0.75rem; color: var(--text-color); display: flex; align-items: center; gap: 5px; opacity: 0.8;"><i class="ri-google-fill"></i> Google</div>
                                                    <% } else { %>
                                                        <div style="font-size: 0.75rem; color: var(--text-color); opacity: 0.8;"><%= t.cargo %>, <%= t.empresa %></div>
                                                    <% } %>
                                                </div>
                                            </div>
                                            <% if (t.origem === 'google' && t.rating) { %>
                                                <div style="color: #f59e0b; display: flex; gap: 2px; margin-bottom: 18px; font-size: 1rem;">
                                                    <% for (let i = 1; i <= 5; i++) { %>
                                                        <i class="<%= i <= t.rating ? 'ri-star-fill' : 'ri-star-line' %>"></i>
                                                    <% } %>
                                                </div>
                                            <% } %>
                                            <p style="font-size: 0.95rem; line-height: 1.6; color: var(--text-color);">"<%= t.texto %>"</p>
                                        </div>
                                        <% if (t.origem === 'google' && t.review_url) { %>
                                            <a href="<%= t.review_url %>" target="_blank" rel="noopener" style="margin-top: 24px; color: var(--navy-blue); text-decoration: none; font-size: 0.75rem; font-weight: 900; text-transform: uppercase; letter-spacing: 1px; display: inline-flex; align-items: center; gap: 6px;">
                                                Ver no Google <i class="ri-arrow-right-up-line"></i>
                                            </a>
                                        <% } %>
                                    </div>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <!-- Fallback Placeholder -->
                            <div class="swiper-slide">
                                <div style="background: var(--bg-sand); border-radius: 24px; padding: 35px; min-height: 250px; display: flex; align-items: center; justify-content: center;">
                                    <p style="color: var(--text-color); opacity: 0.6;">Nenhum depoimento cadastrado.</p>
                                </div>
                            </div>
                        <% } %>
                    </div>
                    <!-- Paginação Customizada -->
                    <div class="swiper-pagination testimonials-pagination" style="position: relative; margin-top: 40px;"></div>
                </div>
            </div>
        </section>

        <!-- CONTATO HOME -->
        <section id="contato" style="background: var(--bg-contact); padding: 100px 0;">
            <div class="container">
                <div style="text-align: center; margin-bottom: 60px;" data-reveal>
                    <span class="section-label">Fale Conosco</span>
                    <h2 style="font-size: 3rem; color: var(--navy-blue); max-width: 900px; margin: 0 auto;">
                        <%- settings.contact_section_title || 'Entre em contato e impulse sua operação' %>
                    </h2>
                    <p style="color: var(--text-color); max-width: 700px; margin: 20px auto 0; font-size: 1rem; line-height: 1.8; opacity: 0.8;">
                        <%= settings.contact_section_subtitle || settings.contact_page_description || 'Fale com nossa equipe para receber atendimento personalizado, tirar dúvidas e agendar uma conversa estratégica.' %>
                    </p>
                </div>

                <style>
                    .contact-home-grid {
                        display: grid; 
                        grid-template-columns: 1fr 1fr; 
                        gap: 40px; 
                        align-items: stretch;
                    }
                    @media (max-width: 900px) {
                        .contact-home-grid {
                            grid-template-columns: 1fr;
                        }
                    }
                </style>
                <div class="contact-home-grid">
                    <div data-reveal="left" style="display: flex; flex-direction: column; gap: 25px;">
                        <div style="background: var(--bg-header); border-radius: 30px; box-shadow: 0 40px 100px rgba(0,0,0,0.08); padding: 40px;">
                            <h3 style="font-size: 1.6rem; margin-bottom: 20px; color: var(--navy-blue);">Dados de contato</h3>
                            <div style="display: grid; gap: 18px;">
                                <div>
                                    <strong style="color: var(--navy-blue);">Telefone</strong>
                                    <p style="margin: 6px 0 0; color: var(--text-color);"><a href="tel:<%= settings.contact_phone ? settings.contact_phone.replace(/\D/g, '') : '' %>" style="color: inherit; text-decoration: none;"><%= settings.contact_phone || '(11) 99999-9999' %></a></p>
                                </div>
                                <div>
                                    <strong style="color: var(--navy-blue);">E-mail</strong>
                                    <p style="margin: 6px 0 0; color: var(--text-color);"><a href="mailto:<%= settings.contact_email || 'contato@seudominio.com' %>" style="color: inherit; text-decoration: none;"><%= settings.contact_email || 'contato@seudominio.com' %></a></p>
                                </div>
                                <div>
                                    <strong style="color: var(--navy-blue);">Endereço</strong>
                                    <p style="margin: 6px 0 0; color: var(--text-color);"><%= settings.address_full || 'Av. Principal, 1000 - Centro' %></p>
                                </div>
                            </div>
                        </div>
                        <div style="background: var(--bg-header); border-radius: 30px; box-shadow: 0 40px 100px rgba(0,0,0,0.08); padding: 40px;">
                            <h3 style="font-size: 1.6rem; margin-bottom: 20px; color: var(--navy-blue);">Gostaria de falar com nosso time?</h3>
                            <p style="margin: 0; color: var(--text-color); line-height: 1.8;">Use os dados acima ou envie sua mensagem pelo formulário de contato na página de administração para que possamos responder rapidamente.</p>
                        </div>
                    </div>
                    <div data-reveal="right" style="height: 100%; min-height: 420px; border-radius: 30px; overflow: hidden; box-shadow: 0 40px 100px rgba(0,0,0,0.08);">
                        <iframe src="<%= settings.contact_map_url || 'https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3657.1973656114175!2d-46.65860718502222!3d-23.561349184683057!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x94ce59c8da563797%3A0x7337220556133f99!2sAv.%20Paulista%2C%20S%C3%A3o%20Paulo%20-%20SP!5e0!3m2!1spt-BR!2sbr!4v1625500000000!5m2!1spt-BR!2sbr' %>" width="100%" height="100%" style="border:0; min-height: 420px; filter: grayscale(0.9) contrast(1.05);" allowfullscreen="" loading="lazy"></iframe>
                    </div>
                </div>
            </div>
        </section>


    </main>

    <%- include('partials/footer') %>

    <!-- Scripts: GSAP + Swiper -->
    <script>
    document.addEventListener('DOMContentLoaded', () => {
        if (window.gsap && window.ScrollTrigger) {
            gsap.registerPlugin(ScrollTrigger);
            gsap.utils.toArray("[data-reveal]").forEach(el => {
            let config = {
                scrollTrigger: { trigger: el, start: "top 90%", toggleActions: "play none none none" },
                opacity: 0, duration: 1.4, ease: "power4.out"
            };
            const direction = el.getAttribute('data-reveal');
            if (direction === 'left') config.x = -60;
            else if (direction === 'right') config.x = 60;
            else config.y = 40;
            gsap.from(el, config);
            });
        }

        if (!window.Swiper) return;

        // Testimonials Swiper
        const testimonialSlides = document.querySelectorAll('.testimonialsSwiper .swiper-slide').length;
        const swiper = new Swiper('.testimonialsSwiper', {
            slidesPerView: 1,
            spaceBetween: 25,
            grabCursor: true,
            loop: testimonialSlides > 4,
            pagination: { el: ".testimonials-pagination", clickable: true },
            breakpoints: {
                768: { slidesPerView: 2 },
                1024: { slidesPerView: 3 },
                1280: { slidesPerView: 4 }
            }
        });

        // Services Swiper (Mobile/Tablet/Desktop)
        const servicesSwiper = new Swiper('.servicesSwiper', {
            slidesPerView: 1,
            spaceBetween: 20,
            centeredSlides: false,
            pagination: { el: ".services-pagination", clickable: true },
            breakpoints: {
                768: { slidesPerView: 2 },
                1024: { slidesPerView: 3 },
                1200: { slidesPerView: 4 }
            }
        });



        // Lógica Newsletter
        // Carrossel de Benefícios
        const beneficiosSlides = document.querySelectorAll('.beneficiosSwiper .swiper-slide').length;
        new Swiper(".beneficiosSwiper", {
            slidesPerView: 1,
            spaceBetween: 20,
            loop: beneficiosSlides > 4,
            autoplay: { delay: 4000, disableOnInteraction: false },
            pagination: { el: ".beneficios-pagination", clickable: true },
            navigation: { nextEl: ".swiper-button-next", prevEl: ".swiper-button-prev" },
            breakpoints: {
                640: { slidesPerView: 1.5 },
                768: { slidesPerView: 2 },
                1024: { slidesPerView: 3 },
                1200: { slidesPerView: 4 }
            }
        });


    });
    </script>
</body>
</html>
