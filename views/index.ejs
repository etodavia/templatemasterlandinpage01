<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <%- include('partials/head-tags') %>
    <% 
        const oColor = settings.hero_overlay_color || '#0A1128';
        const oOpacity = settings.hero_overlay_opacity || 0.4;
        function hexToRgb(hex) {
            hex = hex.replace('#', '');
            const r = parseInt(hex.length === 3 ? hex[0]+hex[0] : hex.substring(0, 2), 16);
            const g = parseInt(hex.length === 3 ? hex[1]+hex[1] : hex.substring(2, 4), 16);
            const b = parseInt(hex.length === 3 ? hex[2]+hex[2] : hex.substring(4, 6), 16);
            return `${r}, ${g}, ${b}`;
        }
        const overlayStyle = `linear-gradient(rgba(${hexToRgb(oColor)}, ${oOpacity}), rgba(${hexToRgb(oColor)}, ${oOpacity}))`;
    %>
    <style>
        .hero { 
            height: 85vh; 
            background: <%= overlayStyle %>, url('<%= settings.hero_image || "/img/hero_optimo.png" %>') center/cover no-repeat;
            margin-top: 0 !important;
            border-top: none !important;
        }
    </style>
</head>
<body style="background: white; padding-top: 0 !important;">
    <%- settings.custom_body_code || '' %>
    <%- include('partials/header') %>

    <main>
        <!-- HERO IMPACTO -->
        <section class="hero">
            <div class="hero-content">
                <h1 data-reveal>
                    <%- settings.home_hero_title || 'Lidere Negócios com <em>Confiança</em>.' %>
                </h1>
                <p data-reveal>
                    <%- settings.home_hero_description || 'Consultoria estratégica especializada em impulsionar o capital humano e elevar a performance operacional.' %>
                </p>
                <div data-reveal style="display: flex; justify-content: flex-start;">
                    <a href="https://wa.me/<%= settings.whatsapp %>" class="btn-pill-large" style="width: auto !important; min-width: 200px; padding: 18px 30px;">
                        Agendar Consultoria <div class="icon-blue-circle" style="background: var(--accent-red); color: white;"><i class="ri-arrow-right-up-line"></i></div>
                    </a>
                </div>
            </div>
            <div class="floating-card" data-reveal style="bottom: 30px;">
                <h4><%- settings.home_hero_card_title || 'Sua empresa em <em>Crescimento</em>.' %></h4>
                <a href="/servicos"><%= settings.home_hero_card_subtitle || 'Experiência Estratégica' %> <i class="ri-arrow-right-line"></i></a>
            </div>
        </section>

        <!-- SOBRE (DINÂMICO) -->
        <section style="background: var(--bg-sand); padding: 100px 0;">
            <div class="container">
                <div class="about-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center;">
                    <div data-reveal="left">
                        <span class="section-label">NOSSA ESSÊNCIA</span>
                        <h2 style="font-size: 3.5rem; line-height: 1; letter-spacing: -3px; margin-bottom: 25px; color: var(--navy-blue);">
                            <%- settings.about_title || 'Sinergia Pura entre <em>Pessoas e Resultados</em>.' %>
                        </h2>
                        <p style="font-size: 1.2rem; color: #555; margin-bottom: 40px; line-height: 1.6;">
                            <%= settings.about_text || 'Na Arque Gestão, acreditamos que a cultura organizacional é o verdadeiro motor da inovação. Nossa abordagem sistêmica conecta os pontos invisíveis que transformam ambientes de trabalho em centros de excelência.' %>
                        </p>
                        <a href="/sobre" class="btn-pill-large" style="background: var(--navy-blue); color: white;">
                            <%= settings.home_about_button_text || 'Conhecer a ARQUÊΔ' %> <div class="icon-blue-circle" style="background: white; color: var(--navy-blue);"><i class="ri-arrow-right-line"></i></div>
                        </a>
                    </div>
                    <div data-reveal="right" class="about-image-wrapper">
                        <img src="<%= settings.about_image || 'https://images.unsplash.com/photo-1543269865-cbf427effbad?auto=format&fit=crop&q=80&w=800' %>" 
                             style="width: 100%; height: 550px; object-fit: cover; border-radius: 40px; box-shadow: 0 40px 100px rgba(0,0,0,0.1);">
                    </div>
                </div>
            </div>
        </section>

        <!-- SERVIÇOS -->
        <style>
            @media (max-width: 1024px) {
                .section-header-flex { flex-direction: column; align-items: flex-start !important; gap: 20px; }
            }
            .servicesSwiper { padding-bottom: 40px; }
            @media (min-width: 1024px) {
                .servicesSwiper .services-wrapper-mobile {
                    display: grid !important;
                    grid-template-columns: repeat(3, 1fr) !important;
                    gap: 25px !important;
                }
                .servicesSwiper .services-slide { width: auto !important; height: auto !important; margin-right: 0 !important; }
                .services-pagination { display: none; }
                .servicesSwiper { padding-bottom: 0; overflow: visible; }
            }
        </style>
        <section id="servicos" style="background: #FAFAFA; padding: 60px 0;">
            <div class="container">
                <div class="section-header-flex" style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 40px;">
                    <div data-reveal="left">
                        <span class="section-label">Especialidades</span>
                        <h2 style="font-size: 2.8rem; color: var(--navy-blue); line-height: 1.1; margin-bottom: 10px;">
                            <%- settings.services_section_title || 'Conheça nossos <em>Serviços</em>' %>
                        </h2>
                        <p style="color: #666; max-width: 500px;"><%= settings.services_section_text %></p>
                    </div>
                    <a href="/servicos" data-reveal="right" class="btn-cta-header" style="background: var(--navy-blue); padding: 16px 30px; border-radius: 12px; font-size: 0.9rem;">
                        <%= settings.home_services_button_text || 'Ver todos os serviços' %>
                    </a>
                </div>
                <div class="swiper servicesSwiper" style="overflow: hidden;">
                    <div class="swiper-wrapper services-wrapper-mobile">
                        <% if (locals.services) { %>
                            <% locals.services.slice(0,3).forEach(s => { %>
                                <div class="swiper-slide services-slide">
                                    <div style="background: white; border-radius: 20px; padding: 35px; box-shadow: 0 4px 20px rgba(0,0,0,0.03); height: 100%; display: flex; flex-direction: column;" data-reveal="up">
                                        <div style="width: 55px; height: 55px; background: #f0f4f8; border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-bottom: 20px;">
                                            <i class="<%= s.icone %>" style="font-size: 1.8rem; color: var(--navy-blue);"></i>
                                        </div>
                                        <h3 style="font-size: 1.4rem; margin-bottom: 15px; color: var(--navy-blue);"><%= s.titulo %></h3>
                                        <p style="color: #666; font-size: 0.9rem; line-height: 1.6;"><%= s.resumo %></p>
                                    </div>
                                </div>
                            <% }) %>
                        <% } %>
                    </div>
                    <div class="swiper-pagination services-pagination" style="position: relative; margin-top: 20px;"></div>
                </div>
            </div>
        </section>
        
        <!-- BENEFÍCIOS (CARROSSEL PREMIUM) -->
        <section id="beneficios" style="padding: 100px 0; background: white; overflow: hidden;">
            <div class="container">
                <div class="section-header" style="text-align: center; margin-bottom: 60px;" data-reveal="up">
                    <span class="section-label">Vantagens Arquê</span>
                    <h2 style="font-size: 2.8rem; color: var(--navy-blue); line-height: 1.1; margin-top: 10px;">
                        <%- settings.benefits_title || 'Benefícios que <em>Transformam</em>' %>
                    </h2>
                    <% if (settings.benefits_text) { %>
                        <p style="color: #64748b; margin-top: 15px; max-width: 600px; margin-left: auto; margin-right: auto;"><%= settings.benefits_text %></p>
                    <% } %>
                </div>

                <div class="swiper beneficiosSwiper" style="padding: 20px 10px 50px 10px;">
                    <div class="swiper-wrapper">
                        <% if (locals.beneficios && beneficios.length > 0) { %>
                            <% beneficios.forEach(b => { %>
                                <div class="swiper-slide">
                                    <div class="beneficio-item" style="background: #F8FAFC; padding: 40px; border-radius: 24px; border: 1px solid #F1F5F9; transition: 0.3s; display: flex; flex-direction: column; gap: 20px; height: 100%;">
                                        <div class="beneficio-icon" style="width: 60px; height: 60px; background: white; border-radius: 16px; display: flex; align-items: center; justify-content: center; font-size: 1.8rem; color: var(--accent-red); box-shadow: 0 10px 20px rgba(0,0,0,0.02);">
                                            <i class="<%= b.icone %>"></i>
                                        </div>
                                        <h3 style="font-size: 1.25rem; font-weight: 800; color: var(--navy-blue); margin: 0;"><%= b.titulo %></h3>
                                        <p style="font-size: 0.95rem; line-height: 1.6; color: #64748b; margin: 0;"><%= b.texto %></p>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <div class="swiper-slide">
                                <div class="beneficio-item" style="background: #F8FAFC; padding: 40px; border-radius: 24px; text-align: center;">
                                    <p style="color: #94a3b8;">Cadastre os benefícios no painel administrativo.</p>
                                </div>
                            </div>
                        <% } %>
                    </div>
                    
                    <!-- Navegação -->
                    <div class="swiper-button-next" style="color: var(--navy-blue); transform: translateX(20px);"></div>
                    <div class="swiper-button-prev" style="color: var(--navy-blue); transform: translateX(-20px);"></div>
                    <div class="swiper-pagination"></div>
                </div>
            </div>
        </section>

        <style>
            .beneficio-item {
                cursor: grab;
                user-select: none;
            }
            .beneficio-item:active {
                cursor: grabbing;
            }
            .beneficio-item:hover {
                transform: translateY(-8px);
                box-shadow: 0 20px 40px rgba(0,0,0,0.08);
                border-color: var(--accent-red);
                background: white !important;
            }
            .beneficiosSwiper .swiper-pagination-bullet-active {
                background: var(--accent-red);
            }
            @media (max-width: 768px) {
                .swiper-button-next, .swiper-button-prev { display: none !important; }
            }
        </style>



        <!-- BLOG -->
        <style>
            .blogSwiper { padding-bottom: 50px; }
            .blog-card {
                background: white; 
                color: var(--navy-blue); 
                padding: 20px; 
                border-radius: 24px; 
                height: 100%;
                display: flex;
                flex-direction: column;
                transition: 0.3s;
                border: 1px solid rgba(0,0,0,0.05);
            }
            .blog-card:hover { transform: translateY(-10px); box-shadow: 0 20px 40px rgba(0,0,0,0.1); }
            .blog-card img { width: 100%; height: 160px; object-fit: cover; border-radius: 16px; margin-bottom: 20px; }
            .blog-card h4 { font-size: 1.15rem; line-height: 1.3; margin-bottom: 12px; font-weight: 800; }
            .blog-card p { font-size: 0.85rem; color: #666; line-height: 1.5; margin-bottom: 20px; flex-grow: 1; }
            .blog-card .btn-read { text-decoration: none; color: var(--navy-blue); font-weight: 900; font-size: 0.75rem; letter-spacing: 1px; display: flex; align-items: center; gap: 5px; }
            
            .blog-pagination { bottom: 0 !important; }
            .blog-pagination .swiper-pagination-bullet-active { background: white !important; }

            @media (min-width: 1024px) {
                .blogSwiper .swiper-wrapper {
                    display: grid !important;
                    grid-template-columns: repeat(4, 1fr) !important;
                    gap: 25px !important;
                }
                .blogSwiper .swiper-slide { width: auto !important; height: auto !important; margin-right: 0 !important; }
                .blog-pagination { display: none; }
                .blogSwiper { overflow: visible; padding-bottom: 0; }
            }
        </style>
        <section id="blog" style="background: var(--navy-blue); color: white; padding: 100px 0;">
            <div class="container">
                <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 60px;">
                    <div data-reveal="left">
                        <span class="section-label" style="color: white; opacity: 0.6;">Insights</span>
                        <h2 style="font-size: 3.2rem; color: white;">
                            <%- settings.blog_section_title || 'Últimos <em>Artigos</em>' %>
                        </h2>
                        <p style="opacity: 0.6; color: white; margin-top: 10px; max-width: 500px;"><%= settings.blog_section_text %></p>
                    </div>
                    <div data-reveal="right" class="desktop-only">
                        <a href="/blog" class="btn-pill-large" style="border: 1px solid rgba(255,255,255,0.2); color: white; background: transparent;">
                            VER TODOS <div class="icon-blue-circle" style="background: white; color: var(--navy-blue);"><i class="ri-arrow-right-line"></i></div>
                        </a>
                    </div>
                </div>

                <div class="swiper blogSwiper">
                    <div class="swiper-wrapper">
                        <% if (posts && posts.length > 0) { %>
                            <% posts.slice(0, 4).forEach(post => { %>
                                <div class="swiper-slide">
                                    <div class="blog-card" data-reveal="up">
                                        <img src="<%= post.imagem %>" alt="<%= post.titulo %>">
                                        <div style="font-size: 0.65rem; font-weight: 900; color: #888; text-transform: uppercase; margin-bottom: 8px; letter-spacing: 1px;"><%= post.categoria %></div>
                                        <h4><%= post.titulo %></h4>
                                        <p><%= post.resumo %></p>
                                        <a href="/blog/<%= post.slug %>" class="btn-read">LER ARTIGO <i class="ri-arrow-right-line"></i></a>
                                    </div>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <div class="swiper-slide" style="width: 100%;">
                                <p style="text-align: center; opacity: 0.5; padding: 40px;">Nenhum artigo publicado ainda.</p>
                            </div>
                        <% } %>
                    </div>
                    <div class="swiper-pagination blog-pagination"></div>
                </div>

                <div style="margin-top: 40px; text-align: center;" class="mobile-only">
                    <a href="/blog" style="color: white; text-decoration: none; font-weight: 800; font-size: 0.9rem;">Ver todos os artigos <i class="ri-arrow-right-line"></i></a>
                </div>
            </div>
        </section>

        <!-- DEPOIMENTOS (EXPANDIDO - 4 COLUNAS COM FOTOS) -->
        <!-- DEPOIMENTOS (CARROSSEL SWIPER PREMIUM) -->
        <section style="background: white; padding: 100px 0; overflow: hidden;">
            <div class="container">
                <div style="text-align: center; margin-bottom: 60px;" data-reveal>
                    <span class="section-label">Cases de Sucesso</span>
                    <h2 style="font-size: 3.2rem; color: var(--navy-blue);">
                        <%- settings.testimonial_section_title || 'O que dizem os <em>Clientes</em>' %>
                    </h2>
                </div>
                
                <div class="swiper testimonialsSwiper">
                    <div class="swiper-wrapper">
                        <% if (testimonials && testimonials.length > 0) { %>
                            <% testimonials.forEach(t => { %>
                                <div class="swiper-slide">
                                    <div style="background: #FAFAFA; border-radius: 24px; padding: 35px; min-height: 250px; display: flex; flex-direction: column; justify-content: space-between;">
                                        <div style="display: flex; align-items: center; gap: 15px; margin-bottom: 25px;">
                                            <img src="<%= t.foto || 'https://images.unsplash.com/photo-1633332755192-727a05c4013d?auto=format&fit=crop&q=80&w=100' %>" 
                                                 style="width: 60px; height: 60px; border-radius: 50%; object-fit: cover;">
                                            <div>
                                                <div style="font-weight: 800; color: var(--navy-blue); font-size: 0.95rem;"><%= t.nome %></div>
                                                <div style="font-size: 0.75rem; color: #888;"><%= t.cargo %>, <%= t.empresa %></div>
                                            </div>
                                        </div>
                                        <p style="font-size: 0.95rem; line-height: 1.6; color: #555;">"<%= t.texto %>"</p>
                                    </div>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <!-- Fallback Placeholder -->
                            <div class="swiper-slide">
                                <div style="background: #FAFAFA; border-radius: 24px; padding: 35px; min-height: 250px; display: flex; align-items: center; justify-content: center;">
                                    <p style="color: #999;">Nenhum depoimento cadastrado.</p>
                                </div>
                            </div>
                        <% } %>
                    </div>
                    <!-- Paginação Customizada -->
                    <div class="swiper-pagination" style="position: relative; margin-top: 40px;"></div>
                </div>
            </div>
        </section>

        <!-- NEWSLETTER -->
        <section style="padding: 60px 0; background: var(--bg-sand);">
            <div class="container">
                <div style="background: var(--navy-blue); color: white; padding: 3rem; border-radius: 30px; text-align: center;">
                    <h2 style="font-size: 2rem; margin-bottom: 0.5rem;">
                        <%- settings.newsletter_section_title || 'Atualize sua <em>Inteligência</em> de RH.' %>
                    </h2>
                    <p style="opacity: 0.7; margin-bottom: 1.5rem;"><%= settings.newsletter_section_text %></p>
                    <form class="newsletter-form" style="max-width: 600px; margin: 0 auto; display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; background: rgba(255,255,255,0.05); padding: 20px; border-radius: 30px; border: 1px solid rgba(255,255,255,0.1);">
                        <input type="text" name="nome" placeholder="Seu nome" required style="flex: 1; min-width: 200px; border: 1px solid rgba(255,255,255,0.2); background: transparent; color: white; padding: 15px 25px; border-radius: 50px; outline: none; font-size: 0.9rem;">
                        <input type="email" name="email" placeholder="Seu melhor e-mail" required style="flex: 1; min-width: 200px; border: 1px solid rgba(255,255,255,0.2); background: transparent; color: white; padding: 15px 25px; border-radius: 50px; outline: none; font-size: 0.9rem;">
                        <button type="submit" style="background: var(--accent-red); color: white; border: none; padding: 15px 35px; border-radius: 50px; font-weight: 800; cursor: pointer; font-size: 0.85rem; transition: 0.3s; width: 100%; max-width: 180px;">INSCREVER</button>
                    </form>
                </div>
            </div>
        </section>
    </main>

    <%- include('partials/footer') %>

    <!-- Scripts: GSAP + Swiper -->
    <script>
        gsap.registerPlugin(ScrollTrigger);
        gsap.utils.toArray("[data-reveal]").forEach(el => {
            let config = {
                scrollTrigger: { trigger: el, start: "top 90%", toggleActions: "play none none none" },
                opacity: 0, duration: 1.4, ease: "power4.out"
            };
            const direction = el.getAttribute('data-reveal');
            if (direction === 'left') config.x = -60;
            else if (direction === 'right') config.x = 60;
            else config.y = 40;
            gsap.from(el, config);
        });

        // Testimonials Swiper
        const swiper = new Swiper('.testimonialsSwiper', {
            slidesPerView: 1,
            spaceBetween: 25,
            grabCursor: true,
            pagination: { el: ".swiper-pagination", clickable: true },
            breakpoints: {
                768: { slidesPerView: 2 },
                1024: { slidesPerView: 3 },
                1280: { slidesPerView: 4 }
            }
        });

        // Benefits Swiper
        const benefitsSwiper = new Swiper('.benefitsSwiper', {
            slidesPerView: 1.2,
            spaceBetween: 20,
            centeredSlides: true,
            loop: true,
            pagination: { el: ".beneficios-pagination", clickable: true },
            breakpoints: {
                768: { slidesPerView: 2.2, centeredSlides: false },
                1024: { enabled: false } // Desativar carrossel no desktop (usar grid)
            }
        });

        // Services Swiper (Mobile/Tablet Only)
        const servicesSwiper = new Swiper('.servicesSwiper', {
            slidesPerView: 1.2,
            spaceBetween: 20,
            centeredSlides: false,
            pagination: { el: ".services-pagination", clickable: true },
            breakpoints: {
                768: { slidesPerView: 2.2 },
                1024: { enabled: false } // Desativar carrossel no desktop (usar grid)
            }
        });

        // Blog Swiper (Mobile/Tablet Only)
        const blogSwiper = new Swiper('.blogSwiper', {
            slidesPerView: 1.2,
            spaceBetween: 20,
            centeredSlides: false,
            pagination: { el: ".blog-pagination", clickable: true },
            breakpoints: {
                768: { slidesPerView: 2.2 },
                1024: { enabled: false } // Desativar no desktop
            }
        });

        // Lógica Newsletter
        // Carrossel de Benefícios
        new Swiper(".beneficiosSwiper", {
            slidesPerView: 1,
            spaceBetween: 20,
            loop: true,
            autoplay: { delay: 4000, disableOnInteraction: false },
            pagination: { el: ".swiper-pagination", clickable: true },
            navigation: { nextEl: ".swiper-button-next", prevEl: ".swiper-button-prev" },
            breakpoints: {
                640: { slidesPerView: 1.5 },
                768: { slidesPerView: 2 },
                1024: { slidesPerView: 3 },
                1200: { slidesPerView: 4 }
            }
        });

        const newsForm = document.querySelector('.newsletter-form');
        if (newsForm) {
            newsForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                const nomeInput = newsForm.querySelector('input[name="nome"]');
                const emailInput = newsForm.querySelector('input[name="email"]');
                const btn = newsForm.querySelector('button');
                
                if (!emailInput.value || !nomeInput.value) return;
                
                btn.disabled = true;
                const originalText = btn.innerText;
                btn.innerText = '...';

                try {
                    const response = await fetch('/api/newsletter', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ 
                            nome: nomeInput.value,
                            email: emailInput.value 
                        })
                    });
                    
                    if (response.ok) {
                        alert('Inscrição realizada com sucesso!');
                        nomeInput.value = '';
                        emailInput.value = '';
                    } else {
                        alert('Erro ao assinar newsletter.');
                    }
                } catch (err) {
                    alert('Falha na conexão.');
                } finally {
                    btn.disabled = false;
                    btn.innerText = originalText;
                }
            });
        }
    </script>
</body>
</html>
