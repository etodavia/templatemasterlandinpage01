<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <%- include('partials/head-tags') %>
    <style>
        .services-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 40px;
            margin-top: 80px;
        }
        .service-item-card {
            text-decoration: none;
            color: inherit;
            display: block;
            overflow: hidden;
            position: relative;
        }
        .service-img-wrapper {
            width: 100%;
            height: 480px;
            overflow: hidden;
            border-radius: 24px;
            margin-bottom: 25px;
            position: relative;
            background: #eee;
        }
        .service-img-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 1.2s cubic-bezier(0.165, 0.84, 0.44, 1);
        }
        .service-item-card:hover .service-img-wrapper img {
            transform: scale(1.1);
        }
        .service-item-card h3 {
            font-size: 2rem;
            color: var(--navy-blue);
            margin-bottom: 10px;
            line-height: 1.1;
            letter-spacing: -1.5px;
            font-weight: 800;
        }
        .service-item-card p {
            font-size: 1rem;
            color: #666;
            line-height: 1.5;
            max-width: 90%;
        }
        .service-icon-circle {
            position: absolute;
            top: 25px;
            right: 25px;
            width: 50px;
            height: 50px;
            background: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            color: var(--navy-blue);
            z-index: 5;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            transition: 0.4s;
        }
        .service-item-card:hover .service-icon-circle {
            background: var(--accent-red);
            color: white;
            transform: rotate(45deg);
        }

        @media (max-width: 1024px) {
            .services-grid { grid-template-columns: repeat(2, 1fr); }
        }
        @media (max-width: 768px) {
            .services-grid { grid-template-columns: 1fr; }
            .service-img-wrapper { height: 350px; }
        }
    </style>
</head>
<body>
    <%- settings.custom_body_code || '' %>
    <%- include('partials/header') %>
    <main>
        <!-- CABEÇALHO DINÂMICO -->
        <%- include('partials/page-hero', { 
            pageTitle: settings.services_hero_title || 'Expertise <em>Estratégica.</em>',
            image: settings.services_hero_image || settings.hero_image,
            imageTablet: settings.services_hero_image_tablet,
            imageMobile: settings.services_hero_image_mobile
        }) %>

        <div class="container" style="margin-top: 100px; margin-bottom: 120px;">
            <div data-reveal style="margin-bottom: 80px;">
                <div style="width: 100px; height: 4px; background: var(--accent-red); margin: 30px 0;"></div>
                <p style="font-size: 1.4rem; color: #666; max-width: 650px; line-height: 1.4;">
                    <%= settings.services_page_description || 'Soluções integradas com Visão Sistêmica para transformar o capital humano em vantagem competitiva.' %>
                </p>
            </div>
            
            <div class="services-grid">
                <% services.forEach((s, index) => { %>
                    <a href="/servicos/<%= s.slug %>" class="service-item-card" data-reveal="up" data-delay="<%= index * 0.1 %>">
                        <div class="service-img-wrapper" style="height: 550px;">
                            <div class="service-icon-circle"><i class="<%= s.icone %>"></i></div>
                            <img src="<%= s.imagem %>" alt="<%= s.titulo %>">
                            <div style="position: absolute; bottom: 20px; left: 20px; color: white; background: rgba(10, 17, 40, 0.4); backdrop-filter: blur(5px); padding: 5px 15px; border-radius: 50px; font-size: 0.65rem; font-weight: 800; letter-spacing: 1px; z-index: 10; border: 1px solid rgba(255,255,255,0.2);">VISÃO SISTÊMICA</div>
                        </div>
                        <h3 style="font-size: 2.5rem; letter-spacing: -2px; margin-top: 15px;"><%= s.titulo %></h3>
                        <p style="font-size: 1.1rem; opacity: 0.8; margin-top: 10px;"><%= s.resumo %></p>
                    </a>
                <% }) %>
            </div>
        </div>
    </main>

    <%- include('partials/footer') %>

    <script>
    document.addEventListener('DOMContentLoaded', () => {
        if (!window.gsap || !window.ScrollTrigger) return;
        gsap.registerPlugin(ScrollTrigger);
        gsap.utils.toArray("[data-reveal]").forEach(el => {
            let config = {
                scrollTrigger: { trigger: el, start: "top 85%", toggleActions: "play none none none" },
                opacity: 0, duration: 1.4, ease: "power4.out"
            };
            const direction = el.getAttribute('data-reveal');
            if (direction === 'up') config.y = 80;
            else if (direction === 'left') config.x = -80;
            else config.y = 40;
            gsap.from(el, config);
        });
    });
    </script>
</body>
</html>
