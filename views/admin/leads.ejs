<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | <%= settings.site_name || 'Sistema' %></title>
    <link rel="stylesheet" href="/css/admin.css">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&display=swap" rel="stylesheet">
</head>
<body>
    <div class="admin-app">
        <%- include('../partials/admin-sidebar') %>
        
        <div class="admin-main">
            <%- include('../partials/admin-header') %>
            <div class="admin-content-scroll">
                <div style="padding: 2.5rem 4rem;">
                    <div class="card-cms">
                        <header style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 50px;">
                            <div>
                                <h1 style="font-size: 2.2rem; margin: 0;">Gestão de <em>Leads</em></h1>
                                <p class="subtitle" style="color: #888; font-size: 0.95rem; margin-top: 5px;">Contatos e oportunidades capturadas através dos formulários do site.</p>
                            </div>
                            <a href="#" id="exportCsv" class="btn-premium" style="background: var(--admin-marinho); color: white; border: none; padding: 12px 25px; border-radius: 50px; text-decoration: none; font-weight: 800; font-size: 0.85rem; display: flex; align-items: center; gap: 8px;"><i class="ri-download-2-line"></i> EXPORTAR CSV</a>
                        </header>

                        <%- include('../partials/admin-alerts') %>

                        <div class="table-responsive">
                            <table id="leadsTable">
                                <thead>
                                    <tr>
                                        <th>Lead / Contato</th>
                                        <th>Mensagem / Interesse</th>
                                        <th>Data</th>
                                        <th style="width: 150px; text-align: right;">Ações</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if(leads && leads.length > 0) { %>
                                        <% leads.forEach(lead => { %>
                                            <tr>
                                                <td>
                                                    <strong style="color: var(--admin-marinho); display: block;"><%= lead.nome %></strong>
                                                    <span style="font-size: 0.75rem; color: #666;"><%= lead.email %></span><br>
                                                    <span style="font-size: 0.75rem; color: #666;"><%= lead.telefone %></span>
                                                </td>
                                                <td>
                                                    <p style="font-size: 0.85rem; color: #444; line-height: 1.4; margin: 0; max-width: 400px;"><%= lead.mensagem %></p>
                                                </td>
                                                <td>
                                                    <span style="font-size: 0.8rem; font-weight: 600; color: #333;"><%= new Date(lead.created_at).toLocaleDateString('pt-BR') %></span>
                                                    <div style="font-size: 0.7rem; opacity: 0.5;"><%= new Date(lead.created_at).toLocaleTimeString('pt-BR', {hour: '2-digit', minute:'2-digit'}) %></div>
                                                </td>
                                                <td style="text-align: right;">
                                                    <div style="display: flex; gap: 10px; justify-content: flex-end;">
                                                        <a href="mailto:<%= lead.email %>?subject=Contato Sua Empresa&body=Olá <%= lead.nome %>," class="btn-action" style="background: #e0f2fe; color: #0284c7; width: 35px; height: 35px; border-radius: 50%; display: flex; align-items: center; justify-content: center; text-decoration: none;" title="Responder"><i class="ri-mail-line"></i></a>
                                                        <a href="https://wa.me/55<%= lead.telefone.replace(/\D/g,'') %>?text=Olá%20<%= encodeURIComponent(lead.nome) %>%2C%20vi%20seu%20contato%20no%20site%20da%20Sua Empresa%20GESTÃO." target="_blank" class="btn-action" style="background: #dcfce7; color: #16a34a; width: 35px; height: 35px; border-radius: 50%; display: flex; align-items: center; justify-content: center; text-decoration: none;" title="WhatsApp"><i class="ri-whatsapp-line"></i></a>
                                                        <form action="/admin/leads/delete/<%= lead.id %>" method="POST" onsubmit="return confirm('Excluir este lead permanentemente?');" style="display: inline;">
                                                            <button type="submit" class="btn-action" style="background: #fff1f2; color: #e11d48; border: none; width: 35px; height: 35px; border-radius: 50%; cursor: pointer;" title="Remover"><i class="ri-delete-bin-line"></i></button>
                                                        </form>
                                                    </div>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    <% } else { %>
                                        <tr><td colspan="4" style="text-align: center; padding: 80px; color: #aaa; background: #f8fafc; border-radius: 20px; border: 2px dashed #eee;">Nenhum lead capturado ainda.</td></tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <%- include('../partials/admin-footer') %>
            </div>
        </div>
    </div>

    <script>
        document.getElementById('exportCsv').addEventListener('click', function(e) {
            e.preventDefault();
            let csv = 'Nome,Email,Telefone,Mensagem,Data\n';
            const rows = document.querySelectorAll('#leadsTable tbody tr');
            
            rows.forEach(row => {
                const cols = row.querySelectorAll('td');
                if(cols.length > 1) {
                    const nome = cols[0].querySelector('strong').innerText;
                    const spans = cols[0].querySelectorAll('span');
                    const email = spans[0].innerText;
                    const tel = spans[1].innerText;
                    const msg = cols[1].innerText.replace(/,/g, ';');
                    const data = cols[2].querySelector('span').innerText;
                    csv += `"${nome}","${email}","${tel}","${msg}","${data}"\n`;
                }
            });

            const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
            const link = document.createElement('a');
            const url = URL.createObjectURL(blob);
            link.setAttribute('href', url);
            link.setAttribute('download', 'leads_arquegestao_' + new Date().toLocaleDateString('pt-BR') + '.csv');
            link.style.visibility = 'hidden';
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        });
    </script>
</body>
</html>
