<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | <%= settings.site_name || 'Sistema Admin' %></title>
    <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&display=swap" rel="stylesheet">
    <style>
        :root { 
            --navy: <%= settings.login_bg_color || '#0A1128' %>; 
            --accent: <%= settings.color_vermelho || '#D62828' %>;
            --bg: #F8FAFC;
            --card-bg: <%= settings.login_card_bg || '#FFFFFF' %>;
            --btn-bg: <%= settings.login_btn_bg || '#0A1128' %>;
        }
        * { margin:0; padding:0; box-sizing:border-box; font-family: 'Inter', sans-serif; }
        body { background: var(--navy); display: flex; align-items: center; justify-content: center; height: 100vh; overflow: hidden; }
        
        body::before {
            content: '';
            position: absolute;
            width: 600px;
            height: 600px;
            background: var(--accent);
            filter: blur(150px);
            opacity: 0.1;
            top: -200px;
            right: -200px;
            border-radius: 50%;
        }

        .login-card { 
            background: var(--card-bg); 
            padding: 60px; 
            border-radius: 40px; 
            width: 450px; 
            box-shadow: 0 40px 80px rgba(0,0,0,0.5); 
            text-align: center; 
            position: relative;
            z-index: 10;
        }
        .login-card h2 { 
            color: var(--navy); 
            margin-bottom: 40px; 
            font-size: 1.8rem; 
            font-weight: 900; 
            letter-spacing: -1px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
        }
        .login-card h2 i { color: var(--accent); font-size: 2rem; }
        
        .form-group { text-align: left; margin-bottom: 25px; }
        .form-group label { display: block; font-size: 0.75rem; font-weight: 900; color: #94A3B8; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 10px; }

        input { 
            width: 100%; 
            padding: 18px 24px; 
            border: 2px solid #F1F5F9; 
            background: #F8FAFC;
            border-radius: 18px; 
            outline: none; 
            transition: 0.3s; 
            font-size: 1rem;
            color: var(--navy);
            font-weight: 600;
        }
        input:focus { border-color: var(--navy); background: white; box-shadow: 0 0 0 5px rgba(10, 17, 40, 0.05); }
        
        button { 
            width: 100%; 
            padding: 20px; 
            background: var(--btn-bg); 
            color: white; 
            border: none; 
            border-radius: 50px; 
            font-weight: 900; 
            cursor: pointer; 
            transition: 0.4s cubic-bezier(0.4, 0, 0.2, 1); 
            letter-spacing: 1px;
            font-size: 0.95rem;
            margin-top: 20px;
        }
        button:hover { background: #000; transform: translateY(-3px); box-shadow: 0 15px 30px rgba(0,0,0,0.2); }
        
        .back-home {
            margin-top: 25px;
            display: block;
            text-decoration: none;
            color: var(--accent);
            font-weight: 800;
            font-size: 0.75rem;
            letter-spacing: 1px;
            transition: 0.3s;
        }
        .back-home:hover { opacity: 0.7; transform: translateX(-5px); }

        .footer-login { 
            margin-top: 50px; 
            border-top: 1px solid #F1F5F9; 
            padding-top: 30px; 
            text-align: center;
        }
        .footer-login p { 
            font-size: 0.6rem; 
            font-weight: 800; 
            color: #CBD5E1; 
            text-transform: uppercase; 
            letter-spacing: 1px; 
            margin-bottom: 15px;
        }
        
        .et-credit {
            text-decoration: none;
            color: #94A3B8;
            font-size: 0.65rem;
            line-height: 1.5;
            display: block;
            transition: 0.3s;
        }
        .et-credit:hover { color: var(--navy); }
        .et-credit i { color: var(--accent); margin-right: 4px; font-size: 0.8rem; }
    </style>
</head>
<body>
    <div class="login-card">
        <div style="margin-bottom: 40px; display: flex; align-items: center; justify-content: center;">
            <% if (settings.login_logo) { %>
                <img src="<%= settings.login_logo %>" alt="CMS Logo" style="max-width: 220px; max-height: 75px; object-fit: contain;">
            <% } else { %>
                <h2 style="color: <%= settings.color_marinho || '#0A1128' %>; margin: 0; font-size: 1.8rem; font-weight: 900; letter-spacing: -1px; display: flex; align-items: center; gap: 12px;">
                    <i class="ri-pulse-fill" style="color: var(--accent); font-size: 2rem;"></i> <%= settings.login_title || 'Sistema CMS' %>
                </h2>
            <% } %>
        </div>
        <form id="loginForm">
            <div class="form-group">
                <label><%= settings.login_label_email || 'Credencial de Acesso' %></label>
                <input type="email" name="email" placeholder="E-mail Corporativo" required>
            </div>
            <div class="form-group">
                <label><%= settings.login_label_password || 'Assinatura de Segurança' %></label>
                <input type="password" name="password" placeholder="••••••••" required>
            </div>
            <button type="submit"><%= settings.login_btn_text || 'ACESSAR GOVERNANÇA' %></button>
        </form>

        <a href="/" class="back-home">
            <i class="ri-arrow-left-line"></i> VOLTAR PARA HOME
        </a>

        <div class="footer-login">
            <p>Digital Governance Platform</p>
            <a href="https://agenciaetodavia.com.br" target="_blank" class="et-credit">
                <i class="ri-shield-check-line"></i> Website produzido exclusivamente pela<br>
                <strong>E-TODAVIA Agência Criativa Ltda</strong><br>
                CNPJ 52.594.366/0001-30
            </a>
        </div>
    </div>

    <script>
        document.getElementById('loginForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const formData = new FormData(e.target);
            const data = Object.fromEntries(formData);
            
            try {
                const response = await fetch('/api/auth/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                
                const result = await response.json();
                if (response.ok) {
                    window.location.href = '/admin/dashboard';
                } else {
                    alert(result.msg || 'Erro ao logar');
                }
            } catch (err) {
                console.error(err);
                alert('Erro de conexão com o servidor.');
            }
        });
    </script>
</body>
</html>
