<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | <%= settings.site_name || 'Sistema' %></title>
    <link rel="stylesheet" href="/css/admin.css">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&display=swap" rel="stylesheet">
</head>
<body>
    <div class="admin-app">
        <%- include('../partials/admin-sidebar') %>
        
        <div class="admin-main">
            <%- include('../partials/admin-header') %>
            <div class="admin-content-scroll">
                <div style="padding: 2.5rem 4rem;">
            <div style="margin-bottom: 2rem;">
                <h1 style="font-size: 1.8rem; color: var(--admin-marinho); font-weight: 800; margin: 0;">Configurações do Sistema</h1>
            </div>

        <%- include('../partials/admin-alerts') %>

        <form action="/admin/config" method="POST">
            <div class="config-grid">
                
                <!-- SEO & GERAL -->
                <div class="config-card">
                    <h3><i class="ri-global-line"></i> SEO & Institucional</h3>
                    <div class="form-group">
                        <label>WhatsApp Oficial (Ex: 5511999999999)</label>
                        <input type="text" name="whatsapp" value="<%= settings.whatsapp %>" placeholder="Apenas Números">
                    </div>
                    <div class="form-group">
                        <label>Meta Título da Home</label>
                        <input type="text" name="meta_title_home" value="<%= settings.meta_title_home %>" placeholder="Título para o Google">
                    </div>
                    <div class="form-group">
                        <label>Meta Descrição da Home</label>
                        <textarea name="meta_description_home" rows="3" placeholder="Descrição para os resultados de busca"><%= settings.meta_description_home %></textarea>
                    </div>
                    <div class="form-group">
                        <label>Keywords (Palavras-Chave)</label>
                        <textarea name="meta_keywords" rows="2" placeholder="gestão, consultoria, arque..."><%= settings.meta_keywords %></textarea>
                    </div>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                        <div class="form-group">
                            <label>CNPJ Empresa</label>
                            <input type="text" name="cnpj" value="<%= settings.cnpj %>">
                        </div>
                        <div class="form-group">
                            <label>Endereço / Sede</label>
                            <input type="text" name="endereco" value="<%= settings.endereco %>">
                        </div>
                    </div>
                </div>

                <!-- ANALYTICS & PIXELS -->
                <div class="config-card">
                    <h3><i class="ri-flashlight-line"></i> Pixels & Tags</h3>
                    <div class="form-group">
                        <label>Google Analytics ID (GT-XXXX)</label>
                        <input type="text" name="google_analytics" value="<%= settings.google_analytics %>">
                    </div>
                    <div class="form-group">
                        <label>Facebook Pixel ID</label>
                        <input type="text" name="facebook_pixel" value="<%= settings.facebook_pixel %>">
                    </div>
                    <div class="form-group">
                        <label>Pinterest Pixel ID</label>
                        <input type="text" name="pinterest_pixel" value="<%= settings.pinterest_pixel %>">
                    </div>
                    <div class="form-group">
                        <label>LinkedIn Insight Tag ID</label>
                        <input type="text" name="linkedin_pixel" value="<%= settings.linkedin_pixel %>">
                    </div>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                         <div class="form-group">
                            <label>SCRIPT HEAD (Personalizado)</label>
                            <textarea name="custom_head_code" rows="4" style="font-family: monospace; font-size: 0.75rem;"><%= settings.custom_head_code %></textarea>
                        </div>
                        <div class="form-group">
                            <label>SCRIPT BODY (Personalizado)</label>
                            <textarea name="custom_body_code" rows="4" style="font-family: monospace; font-size: 0.75rem;"><%= settings.custom_body_code %></textarea>
                        </div>
                    </div>
                </div>

                <!-- SMTP & ENVIO -->
                <div class="config-card">
                    <h3><i class="ri-mail-settings-line"></i> Configuração de E-mail (SMTP)</h3>
                    <p style="font-size: 0.8rem; color: #888; margin-bottom: 2rem;">Necessário para o envio automático de leads e respostas.</p>
                    <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 15px;">
                        <div class="form-group">
                            <label>Servidor SMTP (Ex: smtp.host.com)</label>
                            <input type="text" name="smtp_host" value="<%= settings.smtp_host %>">
                        </div>
                        <div class="form-group">
                            <label>Porta</label>
                            <input type="number" name="smtp_port" value="<%= settings.smtp_port %>" placeholder="465 ou 587">
                        </div>
                    </div>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                        <div class="form-group">
                            <label>Usuário / E-mail</label>
                            <input type="text" name="smtp_user" value="<%= settings.smtp_user %>">
                        </div>
                        <div class="form-group">
                            <label>Senha do SMTP</label>
                            <input type="password" name="smtp_pass" value="<%= settings.smtp_pass %>" placeholder="••••••••••••">
                        </div>
                    </div>
                    
                    <h4 style="font-size: 0.8rem; border-top: 1px solid #eee; padding-top: 15px; margin-top: 20px; color: var(--admin-marinho);">Respostas Automáticas</h4>
                    <div class="form-group">
                        <label>Assunto (E-mail Contato)</label>
                        <input type="text" name="email_subject_contact" value="<%= settings.email_subject_contact %>" placeholder="Ex: Recebemos seu contato!">
                    </div>
                    <div class="form-group">
                        <label>Resposta Automática (Contato)</label>
                        <textarea name="email_reply_contact" rows="4" placeholder="Olá, recebemos sua mensagem e retornaremos em breve..."><%= settings.email_reply_contact %></textarea>
                    </div>

                    <div class="form-group" style="margin-top: 20px;">
                        <label>Assunto (E-mail Newsletter)</label>
                        <input type="text" name="email_subject_newsletter" value="<%= settings.email_subject_newsletter %>" placeholder="Ex: Bem-vindo à nossa Newsletter!">
                    </div>
                    <div class="form-group">
                        <label>Resposta Automática (Newsletter)</label>
                        <textarea name="email_reply_newsletter" rows="4" placeholder="Obrigado por assinar nossa newsletter! Prepare-se para insights exclusivos..."><%= settings.email_reply_newsletter %></textarea>
                    </div>
                </div>

                <!-- AÇÕES -->
                <div class="config-card" style="display: flex; flex-direction: column; justify-content: center; align-items: center; border: 2px dashed #eee; background: #fafafa;">
                    <i class="ri-save-3-fill" style="font-size: 3rem; color: var(--admin-marinho); opacity: 0.1; margin-bottom: 20px;"></i>
                    <p style="text-align: center; font-size: 0.9rem; color: #888; margin-bottom: 30px;">Clique no botão abaixo para aplicar todas as mudanças em tempo real no site público.</p>
                    <button type="submit" class="btn-save">SALVAR TODAS AS ALTERAÇÕES</button>
                    <p style="margin-top: 20px; font-size: 0.75rem; font-weight: 700; color: var(--admin-marinho);">Sua Empresa Admin v<%= settings.template_version || '1.0.0' %></p>
                </div>

            </div>
        </form>

                </div> <!-- padding -->
                <%- include('../partials/admin-footer') %>
            </div> <!-- admin-content-scroll -->
        </div> <!-- admin-main -->
    </div> <!-- admin-app -->
</body>
    <script>
        // Check for success message in URL
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.has('success')) {
            // Keep the message visible
        }
    </script>
</body>
</html>
