<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | <%= settings.site_name || 'Sistema' %></title>
    <link rel="stylesheet" href="/css/admin.css">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&display=swap" rel="stylesheet">
</head>
<body>
    <div class="admin-app">
        <%- include('../partials/admin-sidebar') %>
        
        <div class="admin-main">
            <%- include('../partials/admin-header') %>
            <div class="admin-content-scroll">
                <div style="padding: 2.5rem 4rem;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
                        <div>
                            <h1 style="font-size: 2.2rem; color: var(--admin-marinho); font-weight: 800; margin: 0;">Inscritos <em>Newsletter</em></h1>
                            <p style="color: #888; font-size: 0.95rem; margin-top: 5px;">Base de dados para campanhas e captação de e-mails.</p>
                        </div>
                        <a href="#" id="exportNews" class="btn-premium" style="background: #10b981; color: white; border: none; padding: 12px 25px; border-radius: 50px; text-decoration: none; font-weight: 800; font-size: 0.85rem; display: flex; align-items: center; gap: 8px;">
                            <i class="ri-file-excel-line"></i> EXPORTAR CSV
                        </a>
                    </div>

                    <div class="card-cms" style="background: white; padding: 30px; border-radius: 30px; border: 1px solid #f0f0f0;">
                        <div class="table-responsive">
                            <table id="newsTable">
                                <thead>
                                    <tr>
                                        <th>Nome do Assinante</th>
                                        <th>E-mail</th>
                                        <th>Data de Inscrição</th>
                                        <th style="text-align: right;">Ações</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if(emails && emails.length > 0) { %>
                                        <% emails.forEach(item => { %>
                                            <tr>
                                                <td style="font-weight: 700; color: var(--admin-marinho);"><%= item.nome || 'Não Informado' %></td>
                                                <td><%= item.email %></td>
                                                <td style="opacity: 0.6; font-size: 0.85rem;"><%= new Date(item.created_at).toLocaleDateString('pt-BR') %> às <%= new Date(item.created_at).toLocaleTimeString('pt-BR', {hour: '2-digit', minute:'2-digit'}) %></td>
                                                <td style="text-align: right;">
                                                    <form action="/admin/newsletter/delete/<%= item.id %>" method="POST" onsubmit="return confirm('Excluir este e-mail?');" style="display: inline;">
                                                        <button type="submit" class="btn-action" style="background: #fff1f2; color: #e11d48; border: none; width: 35px; height: 35px; border-radius: 50%; cursor: pointer;"><i class="ri-delete-bin-line"></i></button>
                                                    </form>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    <% } else { %>
                                        <tr><td colspan="4" style="text-align: center; padding: 80px; opacity: 0.4;">Nenhum e-mail inscrito.</td></tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <%- include('../partials/admin-footer') %>
            </div>
        </div>
    </div>

    <script>
        document.getElementById('exportNews').addEventListener('click', function(e) {
            e.preventDefault();
            let csv = 'Nome,Email,InscritoEm\n';
            const rows = document.querySelectorAll('#newsTable tbody tr');
            rows.forEach(row => {
                const cols = row.querySelectorAll('td');
                if(cols.length > 2) {
                    csv += `"${cols[0].innerText}","${cols[1].innerText}","${cols[2].innerText}"\n`;
                }
            });
            const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
            const link = document.createElement('a');
            link.setAttribute('href', URL.createObjectURL(blob));
            link.setAttribute('download', 'newsletter_arque_' + new Date().toLocaleDateString('pt-BR') + '.csv');
            link.click();
        });
    </script>
</body>
</html>
