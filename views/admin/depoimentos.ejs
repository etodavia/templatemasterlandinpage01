<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | <%= settings.site_name || 'Sistema' %></title>
    <link rel="stylesheet" href="/css/admin.css">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&display=swap" rel="stylesheet">
</head>
<body>
    <div class="admin-app">
        <%- include('../partials/admin-sidebar') %>
        
        <div class="admin-main">
            <%- include('../partials/admin-header') %>
            <div class="admin-content-scroll">
                <div style="padding: 2.5rem 4rem;">
                    <header style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px;">
                        <div>
                            <h1 style="font-size: 2.2rem; margin: 0;">Moderação de <em>Depoimentos</em></h1>
                            <p style="color: #888; font-size: 0.95rem; margin-top: 5px;">Aprovação de provas sociais e autoridade de clientes.</p>
                        </div>
                        <div style="display: flex; gap: 15px; flex-wrap: wrap; justify-content: flex-end;">
                            <form action="/admin/depoimentos/sync-google" method="POST" style="display: inline;">
                                <button type="submit" style="background: <%= googleReviewsConfigured ? '#1a73e8' : '#94a3b8' %>; color: white; padding: 12px 25px; border-radius: 50px; border: none; font-weight: 800; font-size: 0.85rem; display: flex; align-items: center; gap: 8px; cursor: pointer;">
                                    <i class="ri-google-fill"></i> SINCRONIZAR GOOGLE
                                </button>
                            </form>
                            <button onclick="copyTestimonialLink()" style="background: #0A1128; color: white; padding: 12px 25px; border-radius: 50px; border: none; font-weight: 800; font-size: 0.85rem; display: flex; align-items: center; gap: 8px; cursor: pointer;">
                                <i class="ri-file-copy-line"></i> COPIAR LINK DE COLETA
                            </button>
                            <a href="/colher-depoimento" target="_blank" style="background: #f1f5f9; color: #0A1128; padding: 12px 25px; border-radius: 50px; text-decoration: none; font-weight: 800; font-size: 0.85rem; display: flex; align-items: center; gap: 8px;"><i class="ri-external-link-line"></i> VER PÁGINA</a>
                        </div>
                    </header>

                    <script>
                        function copyTestimonialLink() {
                            const link = window.location.origin + '/colher-depoimento';
                            navigator.clipboard.writeText(link).then(() => {
                                alert('Link copiado para a área de transferência!');
                            });
                        }
                    </script>

                    <% if (googleSyncSuccess) { %>
                        <div style="background: #ecfdf5; border: 1px solid #bbf7d0; color: #047857; padding: 16px 20px; border-radius: 18px; margin-bottom: 25px; font-size: 0.85rem; font-weight: 800;">
                            <i class="ri-checkbox-circle-fill"></i> Google sincronizado: <%= googleSyncSaved || 0 %> avaliações salvas de <%= googleSyncReceived || 0 %> recebidas.
                        </div>
                    <% } %>
                    <% if (googleSyncError) { %>
                        <div style="background: #fff7ed; border: 1px solid #fed7aa; color: #c2410c; padding: 16px 20px; border-radius: 18px; margin-bottom: 25px; font-size: 0.85rem; font-weight: 800;">
                            <i class="ri-error-warning-fill"></i> Não foi possível sincronizar: <%= googleSyncError %>
                        </div>
                    <% } %>
                    <% if (!googleReviewsConfigured) { %>
                        <div style="background: #f8fafc; border: 1px dashed #cbd5e1; color: #64748b; padding: 16px 20px; border-radius: 18px; margin-bottom: 25px; font-size: 0.85rem; line-height: 1.5;">
                            Para ativar a sincronização, preencha no <strong>.env</strong>: GOOGLE_BUSINESS_ACCOUNT_ID, GOOGLE_BUSINESS_LOCATION_ID, GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET e GOOGLE_REFRESH_TOKEN.
                        </div>
                    <% } %>

                    <section style="background: white; border: 1px solid #f0f0f0; border-radius: 28px; padding: 30px; margin-bottom: 35px;">
                        <div style="display: flex; justify-content: space-between; align-items: center; gap: 20px; margin-bottom: 20px;">
                            <div>
                                <h2 style="font-size: 1.2rem; margin: 0; color: var(--admin-marinho);">Avaliações do Google</h2>
                                <p style="margin: 5px 0 0; color: #94a3b8; font-size: 0.8rem;">Essas avaliações aparecem primeiro na home quando houver itens sincronizados.</p>
                            </div>
                            <span style="font-size: 0.75rem; font-weight: 900; color: #1a73e8; background: #eff6ff; padding: 8px 12px; border-radius: 999px;"><%= googleReviews.length %> no cache</span>
                        </div>
                        <% if (googleReviews.length === 0) { %>
                            <div style="text-align: center; padding: 40px; background: #f8fafc; border-radius: 20px; color: #94a3b8;">
                                <i class="ri-google-fill" style="font-size: 2rem; display: block; margin-bottom: 10px;"></i>
                                Nenhuma avaliação do Google sincronizada ainda.
                            </div>
                        <% } else { %>
                            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 18px;">
                                <% googleReviews.slice(0, 6).forEach(g => { %>
                                    <article style="background: #f8fafc; border-radius: 20px; padding: 22px; border: 1px solid #eef2f7;">
                                        <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 12px;">
                                            <img src="<%= g.profile_photo_url || '/img/placeholder-user.png' %>" style="width: 42px; height: 42px; border-radius: 50%; object-fit: cover;">
                                            <div>
                                                <strong style="display: block; color: #0A1128; font-size: 0.9rem;"><%= g.author_name %></strong>
                                                <span style="color: #f59e0b; font-size: 0.85rem;">
                                                    <% for (let i = 1; i <= 5; i++) { %><i class="<%= i <= g.rating ? 'ri-star-fill' : 'ri-star-line' %>"></i><% } %>
                                                </span>
                                            </div>
                                        </div>
                                        <p style="font-size: 0.85rem; color: #475569; line-height: 1.55; margin: 0;"><%= g.comment %></p>
                                    </article>
                                <% }) %>
                            </div>
                        <% } %>
                    </section>

                    <div class="testimonials-list">
                        <% if (depoimentos.length === 0) { %>
                            <div style="text-align: center; padding: 80px; background: white; border-radius: 30px; border: 1px solid #f0f0f0; color: #aaa;">
                                <i class="ri-chat-quote-line" style="font-size: 3rem; display: block; margin-bottom: 15px; opacity: 0.2;"></i>
                                <p>Nenhum depoimento enviado ainda.</p>
                            </div>
                        <% } else { %>
                            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 25px;">
                                <% depoimentos.forEach(d => { %>
                                    <div style="background: white; padding: 30px; border-radius: 25px; border: 1px solid #f0f0f0; position: relative; transition: 0.3s;" onmouseover="this.style.borderColor='var(--admin-marinho)'" onmouseout="this.style.borderColor='#f0f0f0'">
                                        <div style="display: flex; align-items: center; gap: 15px; margin-bottom: 20px;">
                                            <img src="<%= d.foto || '/img/placeholder-user.png' %>" style="width: 60px; height: 60px; border-radius: 50%; object-fit: cover; border: 3px solid #f8fafc;">
                                            <div>
                                                <h4 style="margin: 0; color: var(--admin-marinho);"><%= d.nome %></h4>
                                                <p style="margin: 0; font-size: 0.75rem; color: #888;"><%= d.cargo %> @ <%= d.empresa %></p>
                                            </div>
                                        </div>
                                        <p style="font-style: italic; color: #444; font-size: 0.9rem; line-height: 1.6; margin-bottom: 25px;">"<%= d.texto %>"</p>
                                        
                                        <div style="display: flex; justify-content: space-between; align-items: center; border-top: 1px solid #f8fafc; pt: 20px; padding-top: 20px;">
                                            <span style="font-size: 0.7rem; color: <%= d.aprovado ? '#10b981' : '#f59e0b' %>; font-weight: 800; text-transform: uppercase; letter-spacing: 1px;">
                                                <%= d.aprovado ? '✓ APROVADO' : '● PENDENTE' %>
                                            </span>
                                            <div style="display: flex; gap: 8px;">
                                                <% if (!d.aprovado) { %>
                                                    <form action="/admin/depoimentos/aprovar/<%= d.id %>" method="POST" style="display: inline;">
                                                        <button type="submit" class="btn-action" style="background: #ecfdf5; color: #10b981; border: none; padding: 8px 15px; border-radius: 12px; font-size: 0.7rem; font-weight: 800; cursor: pointer;">APROVAR</button>
                                                    </form>
                                                <% } %>
                                                <form action="/admin/depoimentos/delete/<%= d.id %>" method="POST" style="display: inline;" onsubmit="return confirm('Excluir depoimento permanentemente?')">
                                                    <button type="submit" class="btn-action" style="background: #fff1f2; color: #e11d48; border: none; padding: 8px 12px; border-radius: 12px; font-size: 0.7rem; font-weight: 800; cursor: pointer;"><i class="ri-delete-bin-line"></i></button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                <% }) %>
                            </div>
                        <% } %>
                    </div>
                </div>
                <%- include('../partials/admin-footer') %>
            </div>
        </div>
    </div>
</body>
</html>
