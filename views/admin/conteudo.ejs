<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | ARQUÊΔ</title>
    <link rel="stylesheet" href="/css/admin.css">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
    <style>
        .cms-layout { display: flex; overflow: hidden; background: #F8FAFC; transition: 0.4s; }
        .cms-tabs-nav { 
            width: 280px; background: white; border-right: 1px solid #eee; 
            padding: 20px 0; overflow-y: auto; flex-shrink: 0; 
            transition: 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
        }
        .cms-tabs-nav.collapsed { width: 85px; }
        .cms-tabs-nav.collapsed .tab-link span, 
        .cms-tabs-nav.collapsed .tab-category-header { display: none; }
        .cms-tabs-nav.collapsed .tab-link { justify-content: center; padding: 15px 0; border-right-width: 4px; }
        .cms-tabs-nav.collapsed .tab-link i { font-size: 1.4rem; margin: 0; }

        .tab-link { padding: 12px 30px; cursor: pointer; display: flex; align-items: center; gap: 12px; color: #64748b; font-size: 0.9rem; font-weight: 600; border-right: 3px solid transparent; transition: 0.3s; }
        .tab-link:hover { color: var(--primary); background: #F1F5F9; }
        .tab-link.active { color: var(--primary); background: #F1F5F9; border-right-color: var(--accent); }
        .tab-link i { font-size: 1.1rem; opacity: 0.7; }
        .tab-category-header { font-size: 0.65rem; font-weight: 800; color: #94a3b8; text-transform: uppercase; letter-spacing: 1px; padding: 20px 30px 10px; }
        .cms-content { flex: 1; padding: 40px; overflow-y: auto; background: white; transition: 0.4s; }
        .tab-panel { display: none; max-width: 900px; margin: 0 auto; }
        .tab-panel.active { display: block; animation: slideUp 0.4s ease-out; }
        @keyframes slideUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

        /* Botão de Encolher Submenu */
        .btn-collapse-sub {
            position: absolute; top: 10px; right: 10px; 
            width: 25px; height: 25px; border-radius: 50%;
            background: #f1f5f9; color: #64748b; border: none;
            cursor: pointer; display: flex; align-items: center; justify-content: center;
            font-size: 0.8rem; z-index: 10; transition: 0.3s;
        }
        .btn-collapse-sub:hover { background: var(--accent); color: white; }

        /* RESPONSIVIDADE MULTI-DISPOSITIVO (TABLET & MOBILE) */
        @media (max-width: 768px) {
            .cms-layout { flex-direction: column; height: auto !important; }
            .cms-tabs-nav { 
                width: 100% !important; height: auto; display: flex; overflow-x: auto; 
                padding: 5px 10px; border-right: none; border-bottom: 1px solid #eee; 
                white-space: nowrap; scrollbar-width: none; -ms-overflow-style: none;
                background: #f8fafc; gap: 5px;
            }
            .cms-tabs-nav.collapsed { width: 100% !important; }
            .btn-collapse-sub { display: none; }
            .cms-tabs-nav span { display: inline !important; font-size: 0.75rem; }
            .cms-tabs-nav::-webkit-scrollbar { display: none; }
            .tab-category-header { display: none; }
            .tab-link { 
                padding: 10px 15px; border-right: none; border-bottom: 2px solid transparent; 
                flex-direction: column; gap: 4px; text-align: center; min-width: 80px;
            }
            .tab-link i { font-size: 1.2rem; }
            .tab-link.active { border-bottom-color: var(--accent); background: white; }
            .cms-content { padding: 20px; }
        }
    </style>
</head>
<body>
    <div class="admin-app">
        <%- include('../partials/admin-sidebar') %>
        
        <div class="admin-main">
            <%- include('../partials/admin-header') %>
            
            <div class="cms-layout">
            <nav class="cms-tabs-nav" id="cmsSubNav">
                <button type="button" class="btn-collapse-sub" onclick="toggleSubNav()"><i class="ri-arrow-left-right-line"></i></button>

                <% if (locals.userRole === 'superadmin') { %>
                <div class="tab-category-header">Soberania</div>
                <div class="tab-link active" onclick="switchTab('tab-licenciamento')" style="border-left: 4px solid var(--accent); background: rgba(214, 40, 40, 0.05); color: var(--accent); font-weight: 900; margin-bottom: 20px;"><i class="ri-shield-keyhole-fill"></i> <span>Licenciamento (Elite)</span></div>
                <% } %>
                <div class="tab-category-header">Global</div>
                <div class="tab-link <%= (locals.userRole !== 'superadmin') ? 'active' : '' %>" onclick="switchTab('tab-identidade')"><i class="ri-fingerprint-line"></i> <span>Identidade & Cores</span></div>
                <div class="tab-link" onclick="switchTab('tab-header')"><i class="ri-layout-top-line"></i> <span>Cabeçalho</span></div>
                <div class="tab-link" onclick="switchTab('tab-redes')"><i class="ri-share-line"></i> <span>Redes Sociais</span></div>
                <div class="tab-link" onclick="switchTab('tab-seo')"><i class="ri-search-line"></i> <span>SEO & Marketing</span></div>
                <% if (locals.userRole === 'superadmin') { %>
                <div class="tab-link" onclick="switchTab('tab-admin-branding')" style="color: #4338ca;"><i class="ri-palette-line"></i> <span>Branding do Painel</span></div>
                <% } %>

                <div class="tab-category-header">Home Page</div>
                <div class="tab-link" onclick="switchTab('tab-home-hero')"><i class="ri-flashlight-line"></i> <span>Hero</span></div>
                <div class="tab-link" onclick="switchTab('tab-home-sobre')"><i class="ri-user-3-line"></i> <span>Sobre</span></div>
                <div class="tab-link" onclick="switchTab('tab-home-servicos')"><i class="ri-service-line"></i> <span>Serviços</span></div>
                <div class="tab-link" onclick="switchTab('tab-home-beneficios')"><i class="ri-star-line"></i> <span>Benefícios</span></div>
                <div class="tab-link" onclick="switchTab('tab-home-artigos')"><i class="ri-article-line"></i> <span>Artigos</span></div>
                <div class="tab-link" onclick="switchTab('tab-home-depoimentos')"><i class="ri-chat-quote-line"></i> <span>Depoimentos</span></div>
                <div class="tab-link" onclick="switchTab('tab-home-newsletter')"><i class="ri-mail-send-line"></i> <span>Newsletter</span></div>

                <div class="tab-category-header">Páginas Internas</div>
                <div class="tab-link" onclick="switchTab('tab-page-sobre')"><i class="ri-pages-line"></i> <span>Página Sobre</span></div>
                <div class="tab-link" onclick="switchTab('tab-page-servicos')"><i class="ri-building-line"></i> <span>Página Serviços</span></div>
                <div class="tab-link" onclick="switchTab('tab-page-blog')"><i class="ri-chat-3-line"></i> <span>Página Blog</span></div>
                <div class="tab-link" onclick="switchTab('tab-page-contato')"><i class="ri-contacts-book-line"></i> <span>Página Contato</span></div>

                <div class="tab-category-header">Estrutura</div>
                <div class="tab-link" onclick="switchTab('tab-footer')"><i class="ri-layout-bottom-line"></i> <span>Rodapé</span></div>
            </nav>

            <form id="cmsForm" action="/admin/conteudo" method="POST" class="cms-content" enctype="multipart/form-data">
                <div style="max-width: 900px; margin: 0 auto;">
                    <%- include('../partials/admin-alerts') %>
                </div>
                
                <!-- IDENTIDADE & CORES -->
                <div id="tab-identidade" class="tab-panel <%= (locals.userRole !== 'superadmin') ? 'active' : '' %>">
                    <div class="section-header"><h3>Identidade Corporativa</h3></div>
                    <div class="form-grid">
                        <div class="form-group">
                            <label>Logo Principal (Colorida)</label>
                            <input type="file" name="logo_file" accept="image/*">
                            <input type="hidden" name="logo" value="<%= settings.logo %>">
                            <% if (settings.logo) { %> <img src="<%= settings.logo %>" class="img-preview"> <% } %>
                        </div>
                        <div class="form-group">
                            <label>Logo Alternativa (Branca)</label>
                            <input type="file" name="logo_white_file" accept="image/*">
                            <input type="hidden" name="logo_white" value="<%= settings.logo_white %>">
                            <% if (settings.logo_white) { %> <img src="<%= settings.logo_white %>" class="img-preview"> <% } %>
                        </div>
                        <div class="form-group">
                            <label>Favicon (Ícone Navegador)</label>
                            <input type="file" name="favicon_file" accept="image/*">
                            <input type="hidden" name="favicon" value="<%= settings.favicon %>">
                            <% if (settings.favicon) { %> <img src="<%= settings.favicon %>" class="img-preview"> <% } %>
                        </div>
                    </div>

                    <div class="section-header" style="margin-top: 40px;"><h3>Engine de Cores</h3></div>
                    <div class="form-grid">
                        <% 
                            const colors = [
                                { label: 'Navy Blue', name: 'color_marinho', value: settings.color_marinho || '#0A1128' },
                                { label: 'Areia', name: 'color_areia', value: settings.color_areia || '#F7F7F4' },
                                { label: 'Vermelho de Destaque', name: 'color_vermelho', value: settings.color_vermelho || '#D62828' },
                                { label: 'Cor do Texto', name: 'color_texto', value: settings.color_texto || '#333333' },
                                { label: 'Fundo do Cabeçalho', name: 'color_header', value: settings.color_header || '#FFFFFF' },
                                { label: 'Texto do Cabeçalho', name: 'color_header_text', value: settings.color_header_text || '#333333' },
                                { label: 'Fundo do Rodapé', name: 'color_footer', value: settings.color_footer || '#0A1128' },
                                { label: 'Texto do Rodapé', name: 'color_footer_text', value: settings.color_footer_text || '#FFFFFF' }
                            ]
                        %>

                        <% colors.forEach(color => { %>
                            <div class="form-group">
                                <div class="color-field-container">
                                    <div class="color-swatch-wrapper">
                                        <div class="color-swatch-preview" style="background-color: <%= color.value %>;"></div>
                                        <input type="color" class="color-input-hidden" value="<%= color.value %>">
                                    </div>
                                    <div class="color-info-wrapper">
                                        <span class="color-name-label"><%= color.label %></span>
                                        <input type="text" name="<%= color.name %>" class="color-hex-input" value="<%= color.value.toUpperCase() %>" maxlength="7">
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>

                <!-- CABEÇALHO -->
                <div id="tab-header" class="tab-panel">
                    <div class="section-header"><h3>Configurações do Topo & Marca</h3></div>
                    <div class="form-group full">
                        <label>Favicon (Ícone do Navegador)</label>
                        <input type="file" name="favicon_file" accept="image/*">
                        <input type="hidden" name="favicon" value="<%= settings.favicon %>">
                        <% if (settings.favicon) { %> <img src="<%= settings.favicon %>" class="img-preview"> <% } %>
                        <p class="field-note"><i class="ri-information-line"></i> Este é o ícone que aparece na aba do navegador.</p>
                    </div>
                    <div class="form-group full">
                        <label>Exibir Topbar (Endereço e Redes no topo)?</label>
                        <select name="show_topbar" style="width: 100%; padding: 12px; border-radius: 50px; border: 1px solid #e0e0e0;">
                            <option value="1" <%= settings.show_topbar == 1 ? 'selected' : '' %>>Sim, exibir topo extra</option>
                            <option value="0" <%= settings.show_topbar == 0 ? 'selected' : '' %>>Não, ocultar topo extra</option>
                        </select>
                    </div>
                    <div class="form-group full">
                        <label>Mensagem da Faixa Superior (Topbar Alert)</label>
                        <input type="text" name="header_strip_text" value="<%= settings.header_strip_text || '' %>" placeholder="Ex: Participe da nossa próxima Mentoria de Liderança!">
                        <p class="field-note"><i class="ri-information-line"></i> Esta mensagem aparecerá na barra preta no topo do site.</p>
                    </div>
                    <div class="form-group full">
                        <label>Endereço à Esquerda</label>
                        <input type="text" name="endereco" value="<%= settings.endereco %>">
                    </div>
                    <div class="form-group full">
                        <label>Botão CTA (Header)</label>
                        <input type="text" name="nav_cta_text" value="<%= settings.nav_cta_text %>">
                    </div>
                    <div class="form-group full">
                        <label>WhatsApp Principal</label>
                        <input type="text" name="whatsapp" value="<%= settings.whatsapp %>">
                    </div>
                    <div class="form-group full">
                        <label>Estrutura do Menu (Um por linha: RÓTULO|LINK)</label>
                        <textarea name="site_menu" placeholder="Home|/
Sobre|/sobre
Serviços|/servicos
Blog|/blog
Contato|/contato"><%= settings.site_menu %></textarea>
                        <p style="font-size: 0.65rem; color: #999; margin-top: 5px;">Use o formato: Nome|/link. Ex: Contato|/contato</p>
                    </div>
                </div>

                <!-- REDES SOCIAIS -->
                <div id="tab-redes" class="tab-panel">
                    <div class="section-header"><h3>Hub de Canais Sociais (8 Slots)</h3></div>
                    <p style="font-size: 0.8rem; color: #64748B; margin-bottom: 30px;">Configure até 8 redes sociais. Apenas links preenchidos aparecerão no site.</p>
                    
                    <% 
                        let socialLinks = [];
                        try {
                            socialLinks = JSON.parse(settings.social_links || '[]');
                        } catch(e) { socialLinks = []; }
                        while(socialLinks.length < 8) socialLinks.push({ network: '', url: '' });

                        const networks = [
                            { id: 'instagram', label: 'Instagram', icon: 'ri-instagram-line' },
                            { id: 'facebook', label: 'Facebook', icon: 'ri-facebook-fill' },
                            { id: 'linkedin', label: 'LinkedIn', icon: 'ri-linkedin-fill' },
                            { id: 'youtube', label: 'YouTube', icon: 'ri-youtube-fill' },
                            { id: 'tiktok', label: 'TikTok', icon: 'ri-tiktok-fill' },
                            { id: 'twitter', label: 'X (Twitter)', icon: 'ri-twitter-x-fill' },
                            { id: 'pinterest', label: 'Pinterest', icon: 'ri-pinterest-fill' },
                            { id: 'google', label: 'Google Business', icon: 'ri-google-fill' }
                        ];
                    %>

                    <input type="hidden" name="social_links" id="socialLinksData">

                    <div class="social-slots-grid" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px;">
                        <% socialLinks.forEach((slot, idx) => { %>
                            <div class="social-slot-item" style="background: #F8FAFC; padding: 20px; border-radius: 20px; border: 1px solid #E2E8F0;">
                                <div style="display: flex; gap: 10px; flex-direction: column;">
                                    <label style="font-size: 0.65rem; font-weight: 900; color: #94A3B8; text-transform: uppercase;">Slot <%= idx + 1 %></label>
                                    <select class="social-network-select" style="padding: 12px; border-radius: 12px; border: 1px solid #E2E8F0; font-weight: 700; color: var(--primary);">
                                        <option value="">-- Selecionar Rede --</option>
                                        <% networks.forEach(net => { %>
                                            <option value="<%= net.id %>" <%= slot.network === net.id ? 'selected' : '' %>><%= net.label %></option>
                                        <% }) %>
                                    </select>
                                    <input type="text" class="social-url-input" placeholder="https://..." value="<%= slot.url %>" style="padding: 12px; border-radius: 12px; border: 1px solid #E2E8F0;">
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>
                
                <!-- SEO & MARKETING -->
                <div id="tab-seo" class="tab-panel">
                    <div class="section-header"><h3>SEO & Estratégia de Marketing</h3></div>
                    
                    <div class="form-grid">
                        <div class="form-group full">
                            <label>Meta Title (Página Inicial)</label>
                            <input type="text" name="meta_title_home" value="<%= settings.meta_title_home %>" placeholder="Título que aparece no Google">
                        </div>
                        <div class="form-group full">
                            <label>Meta Description (Página Inicial)</label>
                            <textarea name="meta_description_home" rows="3" placeholder="Resumo do site para os buscadores"><%= settings.meta_description_home %></textarea>
                        </div>
                        <div class="form-group full">
                            <label>Keywords (Palavras-chave separadas por vírgula)</label>
                            <input type="text" name="meta_keywords" value="<%= settings.meta_keywords %>" placeholder="consultoria, rh, gestão, etc">
                        </div>

                        <div class="section-header" style="margin-top: 40px;"><h4>Rastreamento e Pixels</h4></div>
                        
                        <div class="form-group">
                            <label>Google Analytics ID</label>
                            <input type="text" name="google_analytics" value="<%= settings.google_analytics %>" placeholder="UA-XXXXX-Y ou G-XXXXXXX">
                        </div>
                        <div class="form-group">
                            <label>Facebook Pixel ID</label>
                            <input type="text" name="facebook_pixel" value="<%= settings.facebook_pixel %>" placeholder="Ex: 123456789012345">
                        </div>
                        <div class="form-group">
                            <label>Pinterest Tag ID</label>
                            <input type="text" name="pinterest_pixel" value="<%= settings.pinterest_pixel %>" placeholder="Ex: 261XXXXXXXXXX">
                        </div>
                        <div class="form-group">
                            <label>LinkedIn Insight ID</label>
                            <input type="text" name="linkedin_pixel" value="<%= settings.linkedin_pixel %>" placeholder="Ex: 1234567">
                        </div>

                        <div class="section-header" style="margin-top: 40px;"><h4>Scripts Customizados (Tag Manager / APIs)</h4></div>
                        
                        <div class="form-group full">
                            <label>Scripts no Cabeçalho (Dentro do &lt;head&gt;)</label>
                            <textarea name="custom_head_code" rows="5" placeholder="Cole aqui scripts do Google Tag Manager, Verificação de Domínio, etc"><%= settings.custom_head_code %></textarea>
                            <p class="field-note"><i class="ri-warning-line"></i> Use com cuidado. Códigos mal formatados podem quebrar o site.</p>
                        </div>
                        <div class="form-group full">
                            <label>Scripts no Início do Corpo (Logo após &lt;body&gt;)</label>
                            <textarea name="custom_body_code" rows="5" placeholder="Cole aqui scripts de NoScript, Chatbots, etc"><%= settings.custom_body_code %></textarea>
                        </div>
                    </div>
                </div>
                
                <% if (locals.userRole === 'superadmin') { %>
                <!-- BRANDING DO PAINEL (WHITE LABEL) -->
                <div id="tab-admin-branding" class="tab-panel">
                    <div class="section-header"><h3>Branding do Painel de Controle <span style="background: #4338ca; color: white; padding: 2px 8px; border-radius: 4px; font-size: 0.6rem;">WHITE LABEL</span></h3></div>
                    <p style="font-size: 0.8rem; color: #64748B; margin-bottom: 30px;">Personalize a interface administrativa para cada cliente. Estas cores e logos afetam apenas o ambiente de gestão.</p>
                    
                    <div class="form-grid">
                        <div class="form-group full">
                            <label>Logo do Dashboard (Exibida na Sidebar - Fundo Escuro)</label>
                            <input type="file" name="admin_logo_file" accept="image/*">
                            <input type="hidden" name="admin_logo" value="<%= settings.admin_logo %>">
                            <p class="field-note"><i class="ri-information-line"></i> Recomendado: Logo Branca/Vazada.</p>
                            <% if (settings.admin_logo) { %> <img src="<%= settings.admin_logo %>" class="img-preview" style="background: #0A1128; padding: 10px;"> <% } %>
                        </div>

                        <div class="form-group full">
                            <label>Logo do Topo (Exibida no Cabeçalho - Fundo Claro)</label>
                            <input type="file" name="admin_header_logo_file" accept="image/*">
                            <input type="hidden" name="admin_header_logo" value="<%= settings.admin_header_logo %>">
                            <p class="field-note"><i class="ri-information-line"></i> Recomendado: Logo Colorida/Dark.</p>
                            <% if (settings.admin_header_logo) { %> <img src="<%= settings.admin_header_logo %>" class="img-preview" style="background: #FFFFFF; padding: 10px; border: 1px solid #eee;"> <% } %>
                        </div>

                        <div class="form-group">
                            <label>Cor Primária do Painel (Sidebar/Botões)</label>
                            <div class="color-field-container">
                                <div class="color-swatch-wrapper">
                                    <div class="color-swatch-preview" style="background-color: <%= settings.admin_primary_color || '#0A1128' %>"></div>
                                    <input type="color" class="color-input-hidden" name="admin_primary_color" value="<%= settings.admin_primary_color || '#0A1128' %>">
                                </div>
                                <div class="color-info-wrapper">
                                    <span class="color-name-label">Primary Admin</span>
                                    <input type="text" class="color-hex-input" value="<%= settings.admin_primary_color || '#0A1128' %>">
                                </div>
                            </div>
                        </div>

                        <div class="form-group">
                            <label>Cor de Destaque (Accent)</label>
                            <div class="color-field-container">
                                <div class="color-swatch-wrapper">
                                    <div class="color-swatch-preview" style="background-color: <%= settings.admin_accent_color || '#D62828' %>"></div>
                                    <input type="color" class="color-input-hidden" name="admin_accent_color" value="<%= settings.admin_accent_color || '#D62828' %>">
                                </div>
                                <div class="color-info-wrapper">
                                    <span class="color-name-label">Accent Admin</span>
                                    <input type="text" class="color-hex-input" value="<%= settings.admin_accent_color || '#D62828' %>">
                                </div>
                            </div>
                        </div>
                    </div>

                    <div style="margin-top: 40px; padding: 25px; background: #EEF2FF; border-radius: 20px; border: 1px solid #C7D2FE; color: #4338ca;">
                        <h4 style="font-size: 0.85rem; font-weight: 800; margin-bottom: 10px; display: flex; align-items: center; gap: 8px;">
                            <i class="ri-lightbulb-line"></i> DICA DE REUSO
                        </h4>
                        <p style="font-size: 0.75rem; line-height: 1.6; font-weight: 500;">
                            Ao configurar um novo cliente, você pode alterar essas cores para combinar com a marca dele, dando uma sensação de plataforma exclusiva. Isso valoriza a sua entrega como agência.
                        </p>
                    </div>
                </div>
                <% } %>

                <div id="tab-home-hero" class="tab-panel">
                    <div class="section-header"><h3>Home Page » Seção Hero</h3></div>
                    <div class="form-grid">
                        <div class="form-group">
                            <label>Imagem de Fundo (1200x900px recomendado)</label>
                            <input type="file" name="hero_image_file" accept="image/*">
                            <input type="hidden" name="hero_image" value="<%= settings.hero_image %>">
                            <% if (settings.hero_image) { %> <img src="<%= settings.hero_image %>" class="img-preview"> <% } %>
                        </div>
                        <div class="form-group">
                            <label>Cor da Sobreposição (Overlay)</label>
                            <input type="color" name="hero_overlay_color" value="<%= settings.hero_overlay_color || '#0A1128' %>" style="width: 100%; height: 45px; padding: 5px; border-radius: 12px; border: 1px solid #E2E8F0; cursor: pointer;">
                        </div>
                        <div class="form-group">
                            <label>Opacidade do Overlay (0.00 a 1.00)</label>
                            <input type="number" name="hero_overlay_opacity" value="<%= settings.hero_overlay_opacity || 0.4 %>" step="0.05" min="0" max="1" style="padding: 12px; border-radius: 12px; border: 1px solid #E2E8F0; width: 100%;">
                        </div>
                        <div class="form-group">
                            <label>Título de Impacto</label>
                            <input type="text" name="home_hero_title" value="<%= settings.home_hero_title %>">
                            <p class="field-note"><i class="ri-information-line"></i> Use &lt;em&gt;texto&lt;/em&gt; para aplicar a fonte alternada.</p>
                        </div>
