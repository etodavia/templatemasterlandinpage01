                    </div>
                    <div class="form-grid">
                        <div class="form-group full" style="background: rgba(214, 40, 40, 0.05); padding: 25px; border-radius: 12px; border-left: 5px solid var(--accent);">
                            <p style="font-size: 0.85rem; color: var(--primary); font-weight: 700; margin-bottom: 20px;">Esta seção é destinada à autenticidade da sua licença ARQUÊΔ. Os dados inseridos aqui serão exibidos exclusivamente no seu Cockpit de Inteligência (Dashboard).</p>
                            
                            <div style="display: grid; grid-template-columns: 1fr 2fr; gap: 30px; align-items: start;">
                                <div class="form-group">
                                    <label>QR Code de Autenticação (Imagem)</label>
                                    <input type="file" name="license_qr_code_file" accept="image/*">
                                    <input type="hidden" name="license_qr_code" value="<%= settings.license_qr_code %>">
                                    <% if (settings.license_qr_code) { %> <img src="<%= settings.license_qr_code %>" class="img-preview" style="width: 150px; height: 150px; border: 1px solid #ddd;"> <% } %>
                                </div>
                                <div class="form-group">
                                    <label>Dados de Verificação (Nota Fiscal / Contrato)</label>
                                    <textarea name="license_nf_data" style="min-height: 200px; font-family: monospace; font-size: 0.8rem;" placeholder="Ex: NF-e: 000.123.456&#10;Série: 001&#10;Emissão: 10/05/2026&#10;Licença: ARQUE-Enterprise-2026"><%= settings.license_nf_data %></textarea>
                                </div>
                            </div>

                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px; margin-top: 30px; border-top: 1px solid rgba(0,0,0,0.1); padding-top: 30px;">
                                <div class="form-group">
                                    <label>Código de Autenticação (Cloud ID / Hash)</label>
                                    <div style="display: flex; gap: 10px;">
                                        <input type="text" id="auth_code_input" name="license_auth_code" value="<%= settings.license_auth_code %>" placeholder="Ex: BSB-8923-M9SI" style="flex: 1;">
                                        <button type="button" onclick="generateHash()" class="btn-premium" style="background: #F1F5F9; color: var(--primary); padding: 0 15px; font-size: 0.6rem; font-weight: 900; white-space: nowrap;"><i class="ri-refresh-line"></i> GERAR HASH</button>
                                    </div>
                                    <script>
                                        function generateHash() {
                                            const chars = '0123456789ABCDEF';
                                            let res = 'ET-';
                                            for(let i=0; i<4; i++) res += chars[Math.floor(Math.random() * 16)];
                                            res += '-';
                                            for(let i=0; i<4; i++) res += chars[Math.floor(Math.random() * 16)];
                                            document.getElementById('auth_code_input').value = res;
                                        }
                                    </script>
                                </div>
                                <div class="form-group">
                                    <label>Documento de Compra (PDF da NF)</label>
                                    <input type="file" name="license_pdf_file" accept=".pdf">
                                    <input type="hidden" name="license_pdf" value="<%= settings.license_pdf %>">
                                    <% if (settings.license_pdf) { %>
                                        <div style="margin-top: 5px; font-size: 0.7rem; color: var(--accent); font-weight: 700;">
                                            <i class="ri-file-pdf-line"></i> PDF Carregado: <a href="<%= settings.license_pdf %>" target="_blank" style="color: inherit;">Visualizar Documento</a>
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <% } %>
                <%- include('../partials/admin-footer') %>
            </form>
            </div> <!-- cms-layout -->
        </div> <!-- admin-main -->
    </div> <!-- admin-app -->
</body>
    <script>
        function toggleSubNav() {
            const nav = document.getElementById('cmsSubNav');
            nav.classList.toggle('collapsed');
            localStorage.setItem('cmsSubNavCollapsed', nav.classList.contains('collapsed'));
        }

        function switchTab(tabId) {
            document.querySelectorAll('.tab-link').forEach(el => el.classList.remove('active'));
            document.querySelectorAll('.tab-panel').forEach(el => el.classList.remove('active'));
            
            const activeLink = document.querySelector(`[onclick="switchTab('${tabId}')"]`);
            if(activeLink) activeLink.classList.add('active');
            
            const activePanel = document.getElementById(tabId);
            if(activePanel) activePanel.classList.add('active');
        }

        // Roteamento de Aba via URL (Licenciamento Elite)
        window.onload = function() {
            // Aplicar estado do submenu
            if (localStorage.getItem('cmsSubNavCollapsed') === 'true') {
                document.getElementById('cmsSubNav').classList.add('collapsed');
            }

            const urlParams = new URLSearchParams(window.location.search);
            const targetTab = urlParams.get('tab');
            if (targetTab) {
                switchTab(targetTab);
            }
        };

        // Sincronização da Engine de Cores
        document.querySelectorAll('.color-field-container').forEach(container => {
            const colorInput = container.querySelector('.color-input-hidden');
            const hexInput = container.querySelector('.color-hex-input');
            const swatch = container.querySelector('.color-swatch-preview');

            // Do Seletor para o Texto
            colorInput.addEventListener('input', (e) => {
                const color = e.target.value.toUpperCase();
                hexInput.value = color;
                swatch.style.backgroundColor = color;
            });

            // Do Texto para o Seletor
            hexInput.addEventListener('input', (e) => {
                let val = e.target.value;
                if (val.length > 0 && !val.startsWith('#')) {
                    val = '#' + val;
                    hexInput.value = val;
                }
                if (/^#[0-9A-F]{6}$/i.test(val)) {
                    colorInput.value = val;
                    swatch.style.backgroundColor = val;
                }
            });
        });

        // Atualização de Preview de Ícone em Tempo Real
        function updateIconPreview(input) {
            const preview = input.parentElement.querySelector('i');
            const val = input.value.trim();
            preview.className = val || 'ri-star-line';
        }

        // Hub de Redes Sociais: Consolidação JSON
        document.getElementById('cmsForm').addEventListener('submit', function(e) {
            const slots = [];
            document.querySelectorAll('.social-slot-item').forEach(item => {
                const network = item.querySelector('.social-network-select').value;
                const url = item.querySelector('.social-url-input').value.trim();
                
                if (network && url) {
                    slots.push({ network, url });
                }
            });
            document.getElementById('socialLinksData').value = JSON.stringify(slots);

            // Hub de Diferenciais: Consolidação JSON
            const benefits = [];
            document.querySelectorAll('.benefit-slot-item').forEach(item => {
                const icon = item.querySelector('.b-item-icon').value.trim();
                const title = item.querySelector('.b-item-title').value.trim();
                const text = item.querySelector('.b-item-text').value.trim();
                
                if (icon || title || text) {
                    benefits.push({ icon, title, text });
                }
            });
            document.getElementById('benefitsData').value = JSON.stringify(benefits);

            // Consolidação JSON do Editor de Formulário
            document.getElementById('contact_form_fields_json').value = JSON.stringify(formFields);
        });

        // --- EDITOR DE FORMULÁRIO DINÂMICO ---
        let formFields = [];
        try {
            formFields = JSON.parse(document.getElementById('contact_form_fields_json').value || '[]');
        } catch(e) { formFields = []; }

        function renderFormFields() {
            const container = document.getElementById('form-fields-list');
            if (!container) return;
            container.innerHTML = '';
            
            if (formFields.length === 0) {
                container.innerHTML = '<p style="text-align: center; color: #94a3b8; font-size: 0.75rem; padding: 20px;">Nenhum campo personalizado. O formulário usará o padrão (Nome, E-mail, Mensagem).</p>';
            }

            formFields.forEach((field, index) => {
                const div = document.createElement('div');
                div.style = "display: grid; grid-template-columns: 2fr 1fr 1fr 40px; gap: 10px; align-items: center; background: white; padding: 10px; border-radius: 10px; border: 1px solid #eee;";
                div.innerHTML = `
                    <input type="text" placeholder="Nome do Campo" value="${field.label}" onchange="updateFormField(${index}, 'label', this.value)" style="padding: 8px; font-size: 0.8rem;">
                    <select onchange="updateFormField(${index}, 'type', this.value)" style="padding: 8px; font-size: 0.8rem;">
                        <option value="text" ${field.type === 'text' ? 'selected' : ''}>Texto Curto</option>
                        <option value="email" ${field.type === 'email' ? 'selected' : ''}>E-mail</option>
                        <option value="tel" ${field.type === 'tel' ? 'selected' : ''}>Telefone</option>
                        <option value="textarea" ${field.type === 'textarea' ? 'selected' : ''}>Texto Longo</option>
                    </select>
                    <label style="font-size: 0.7rem; display: flex; align-items: center; gap: 5px; cursor: pointer; margin: 0;">
                        <input type="checkbox" ${field.required ? 'checked' : ''} onchange="updateFormField(${index}, 'required', this.checked)"> Obrigatório
                    </label>
                    <button type="button" onclick="removeFormField(${index})" style="background: #fee2e2; color: #ef4444; border: none; width: 30px; height: 30px; border-radius: 6px; cursor: pointer;"><i class="ri-delete-bin-line"></i></button>
                `;
                container.appendChild(div);
            });
            
            document.getElementById('contact_form_fields_json').value = JSON.stringify(formFields);
        }

        window.addFormField = function() {
            formFields.push({ label: '', type: 'text', required: true });
            renderFormFields();
        };

        window.removeFormField = function(index) {
            formFields.splice(index, 1);
            renderFormFields();
        };

        window.updateFormField = function(index, key, value) {
            formFields[index][key] = value;
            document.getElementById('contact_form_fields_json').value = JSON.stringify(formFields);
        };

        // Iniciar renderização se estivermos na aba de contato
        renderFormFields();
    </script>

