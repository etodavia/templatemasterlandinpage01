<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | <%= settings.site_name || 'Sistema' %></title>
    <link rel="stylesheet" href="/css/admin.css">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
    <div class="admin-app">
        <%- include('../partials/admin-sidebar') %>
        
        <div class="admin-main">
            <%- include('../partials/admin-header') %>
            
            <div class="admin-content-scroll">
                <div style="padding: 2.5rem 4rem;">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: center; margin-bottom: 40px;">
            <div>
                <h1 style="font-size: 2.2rem; margin: 0; color: #000033;">Bem-vindo ao <em>Painel</em></h1>
                <p class="subtitle" style="margin: 10px 0 0; opacity: 0.6; font-size: 1.1rem; line-height: 1.5;">Gerencie o conteúdo do seu site e acompanhe os dados.</p>
            </div>

            <% if (settings.admin_tutorial_video || settings.admin_tutorial_image) { %>
            <div style="background: #f8fafc; border-radius: 20px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.05); text-align: center;">
                <% if (settings.admin_tutorial_image) { %>
                    <a href="<%= settings.admin_tutorial_video || '#' %>" target="_blank" style="display: block; position: relative;">
                        <img src="<%= settings.admin_tutorial_image %>" style="width: 100%; height: auto; display: block; object-fit: cover; border-bottom: 1px solid #e2e8f0;">
                        <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: rgba(0,0,0,0.6); color: white; width: 60px; height: 60px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 2rem;">
                            <i class="ri-play-fill"></i>
                        </div>
                    </a>
                <% } else { %>
                    <div style="padding: 40px; background: #e2e8f0;">
                        <i class="ri-image-line" style="font-size: 3rem; color: #94a3b8;"></i>
                    </div>
                <% } %>
                <div style="padding: 20px;">
                    <a href="<%= settings.admin_tutorial_video || '#' %>" target="_blank" class="btn-premium" style="display: inline-flex; width: auto; padding: 12px 30px; font-size: 0.9rem; margin-top: 0;">
                        <i class="ri-external-link-line"></i> Assistir ao Vídeo de Treinamento
                    </a>
                </div>
            </div>
            <% } else { %>
            <div style="background: #f8fafc; border: 2px dashed #e2e8f0; border-radius: 20px; padding: 30px; text-align: center; color: #94a3b8;">
                <i class="ri-video-line" style="font-size: 2.5rem; margin-bottom: 10px; display: block;"></i>
                <h3 style="font-size: 1.1rem; color: #0f172a; margin-bottom: 5px;">Vídeo de Treinamento</h3>
                <p style="font-size: 0.85rem;">Nenhuma capa ou link configurados.</p>
            </div>
            <% } %>
        </div>

        <!-- AUTENTICAÇÃO DE PROPRIEDADE (CERTIFICADO DIGITAL - VISÍVEL PARA SUPERADMIN E ADMIN) -->
        <% if (locals.userRole === 'superadmin' || locals.userRole === 'admin') { %>
        <div style="margin-top: 30px; display: grid; grid-template-columns: 1fr 2fr; gap: 30px;">
            <div style="background: white; padding: 30px; border-radius: 24px; border: 1px solid var(--border); display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center;">
                <h4 style="font-size: 0.65rem; font-weight: 900; color: var(--text-muted); text-transform: uppercase; margin-bottom: 15px; letter-spacing: 1px;">Autenticação Digital</h4>
                <% if (settings.license_qr_code) { %>
                    <img src="<%= settings.license_qr_code %>" style="width: 140px; height: 140px; object-fit: contain; margin-bottom: 15px;">
                <% } else { %>
                    <div style="width: 140px; height: 140px; background: #f8fafc; border: 2px dashed #e2e8f0; border-radius: 12px; display: flex; align-items: center; justify-content: center; color: #94a3b8; font-size: 2rem; margin-bottom: 15px;">
                        <i class="ri-qr-code-line"></i>
                    </div>
                <% } %>
                <span style="font-size: 0.6rem; font-weight: 800; color: var(--accent); background: rgba(214, 40, 40, 0.05); padding: 4px 10px; border-radius: 4px;">SITE REGISTRADO</span>
            </div>

            <div style="background: white; padding: 30px; border-radius: 24px; border: 1px solid var(--border);">
                <h4 style="font-size: 0.65rem; font-weight: 900; color: var(--text-muted); text-transform: uppercase; margin-bottom: 15px; letter-spacing: 1px;">Dados de Aquisição do Ecossistema</h4>
                <div style="font-family: 'Courier New', Courier, monospace; font-size: 0.75rem; line-height: 1.5; color: var(--primary); background: #f8fafc; padding: 15px; border-radius: 12px; border: 1px solid #e2e8f0; min-height: 100px;">
                    <%- settings.license_nf_data ? settings.license_nf_data.replace(/\n/g, '<br>') : 'Aguardando sincronização de dados fiscais...' %>
                </div>
                <div style="margin-top: 15px; display: flex; justify-content: space-between; align-items: center; font-size: 0.6rem; font-weight: 900; color: #94a3b8; text-transform: uppercase;">
                    <div>
                        <span style="display: block; margin-bottom: 4px;">AUTH CODE: <span style="color: var(--primary);"><%= settings.license_auth_code || 'PENDENTE' %></span></span>
                        <span>Hash ID: <%= Math.random().toString(36).substring(7).toUpperCase() %></span>
                    </div>
                    <% if (settings.license_pdf) { %>
                        <a href="<%= settings.license_pdf %>" target="_blank" style="background: var(--primary); color: white; padding: 8px 15px; border-radius: 6px; text-decoration: none; display: flex; align-items: center; gap: 8px;">
                            <i class="ri-file-pdf-line"></i> VER NF (PDF)
                        </a>
                    <% } %>
                </div>
            </div>
        </div>
        <% } %>

            </div> <!-- padding -->
            <%- include('../partials/admin-footer') %>
        </div> <!-- admin-content-scroll -->
    </div> <!-- admin-main -->
</div> <!-- admin-app -->


</body>
</html>
