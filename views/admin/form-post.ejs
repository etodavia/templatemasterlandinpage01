<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | <%= settings.site_name || 'Sistema' %></title>
    <link rel="stylesheet" href="/css/admin.css">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&display=swap" rel="stylesheet">
    <!-- Quill Rich Text Editor -->
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
</head>
<body>
    <div class="admin-app">
        <%- include('../partials/admin-sidebar') %>
        
        <div class="admin-main">
            <%- include('../partials/admin-header') %>
            
            <div class="admin-content-scroll">
                <div style="padding: 2.5rem 4rem;">
                    <div style="max-width: 900px; margin: 0 auto; background: white; padding: 40px; border-radius: 30px; border: 1px solid #f0f0f0; box-shadow: 0 15px 40px rgba(0,0,0,0.02);">
                        <header style="margin-bottom: 40px; display: flex; justify-content: space-between; align-items: center;">
                            <div>
                                <h2 style="font-size: 2rem; color: #0A1128; margin: 0;"><%= post ? 'Editar' : 'Criar' %> Artigo no <em>Blog</em></h2>
                                <p style="color: #888; font-size: 0.9rem; margin-top: 5px;">O conhecimento da Sistema sendo compartilhado com autoridade.</p>
                            </div>
                            <a href="/admin/posts" style="text-decoration: none; color: #666; font-weight: 700; font-size: 0.8rem; display: flex; align-items: center; gap: 5px;">
                                <i class="ri-arrow-left-line"></i> VOLTAR
                            </a>
                        </header>

                        <form action="<%= post ? '/admin/posts/editar/' + post.id : '/admin/posts' %>" method="POST" enctype="multipart/form-data">
                            <div style="text-align: center; margin-bottom: 40px; background: #F8FAFC; padding: 40px; border-radius: 24px; border: 1px dashed #ddd;">
                                <img id="imgPreview" src="<%= post ? post.imagem : '/img/placeholder-post.png' %>" 
                                     style="width: 100%; max-width: 400px; height: 200px; border-radius: 12px; object-fit: cover; border: 5px solid white; box-shadow: 0 10px 25px rgba(0,0,0,0.05); margin-bottom: 20px;">
                                
                                <input type="file" name="imagem_file" id="fileInput" accept="image/*" style="display: none;">
                                <button type="button" onclick="document.getElementById('fileInput').click()" 
                                        style="display: block; width: 220px; margin: 0 auto; background: #0A1128; color: white; border: none; padding: 12px; border-radius: 50px; font-size: 0.7rem; font-weight: 900; cursor: pointer; text-transform: uppercase; letter-spacing: 1px; transition: 0.3s;">
                                    <i class="ri-camera-lens-line"></i> ALTERAR IMAGEM DE CAPA
                                </button>
                                <input type="hidden" name="imagem" value="<%= post ? post.imagem : '' %>">
                            </div>

                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 25px; margin-bottom: 25px;">
                                <div class="form-group">
                                    <label style="display: block; font-weight: 800; font-size: 0.75rem; color: #666; margin-bottom: 10px; text-transform: uppercase;">Título do Artigo</label>
                                    <input type="text" name="titulo" placeholder="Ex: O Futuro da Liderança" required onkeyup="generateSlug(this.value)" value="<%= post ? post.titulo : '' %>" style="width: 100%; padding: 15px; border: 1px solid #eee; border-radius: 12px; font-size: 1rem;">
                                </div>
                                <div class="form-group">
                                    <label style="display: block; font-weight: 800; font-size: 0.75rem; color: #666; margin-bottom: 10px; text-transform: uppercase;">Slug (URL amigável)</label>
                                    <input type="text" name="slug" id="slugInput" placeholder="ex: futuro-da-lideranca" required value="<%= post ? post.slug : '' %>" style="width: 100%; padding: 15px; border: 1px solid #eee; border-radius: 12px; font-size: 1rem;">
                                </div>
                            </div>

                            <div class="form-group" style="margin-bottom: 25px;">
                                <label style="display: block; font-weight: 800; font-size: 0.75rem; color: #666; margin-bottom: 10px; text-transform: uppercase;">Categoria</label>
                                <select name="categoria" style="width: 100%; padding: 15px; border: 1px solid #eee; border-radius: 12px; font-size: 1rem;">
                                    <% ['GESTÃO', 'LIDERANÇA', 'CULTURA', 'ESTRATÉGIA'].forEach(cat => { %>
                                        <option value="<%= cat %>" <%= post && post.categoria === cat ? 'selected' : '' %>><%= cat %></option>
                                    <% }) %>
                                </select>
                            </div>

                            <div class="form-group" style="margin-bottom: 25px;">
                                <label style="display: block; font-weight: 800; font-size: 0.75rem; color: #666; margin-bottom: 10px; text-transform: uppercase;">Resumo (Card de Listagem)</label>
                                <textarea name="resumo" placeholder="Uma breve descrição que convide à leitura..." required style="width: 100%; padding: 15px; border: 1px solid #eee; border-radius: 12px; font-size: 1rem; min-height: 100px; resize: vertical;"><%= post ? post.resumo : '' %></textarea>
                            </div>

                            <div class="form-group" style="margin-bottom: 25px;">
                                <label style="display: block; font-weight: 800; font-size: 0.75rem; color: #666; margin-bottom: 10px; text-transform: uppercase;">Conteúdo Completo</label>
                                <div id="quill-editor" style="height: 400px; border-radius: 0 0 12px 12px; font-family: 'Inter', sans-serif;"><%- post ? post.conteudo : '' %></div>
                                <input type="hidden" name="conteudo" id="hiddenConteudo">
                            </div>

                            <div style="margin-top: 40px; padding: 30px; background: #f8fafc; border-radius: 24px; border: 1px solid #f0f0f0;">
                                <h4 style="margin: 0 0 20px; font-size: 0.8rem; letter-spacing: 1px; color: #0A1128; text-transform: uppercase;">Otimização de SEO (Busca)</h4>
                                <div class="form-group" style="margin-bottom: 20px;">
                                    <label style="display: block; font-weight: 800; font-size: 0.75rem; color: #666; margin-bottom: 10px; text-transform: uppercase;">Título SEO (Meta Title)</label>
                                    <input type="text" name="meta_title" placeholder="Aparecerá na aba do navegador e no Google" value="<%= post ? post.meta_title : '' %>" style="width: 100%; padding: 15px; border: 1px solid #eee; border-radius: 12px; font-size: 1rem;">
                                </div>
                                <div class="form-group" style="margin-bottom: 0;">
                                    <label style="display: block; font-weight: 800; font-size: 0.75rem; color: #666; margin-bottom: 10px; text-transform: uppercase;">Descrição SEO (Meta Description)</label>
                                    <textarea name="meta_description" placeholder="Aparecerá no resumo do Google (ideal 160 caracteres)" style="width: 100%; padding: 15px; border: 1px solid #eee; border-radius: 12px; font-size: 1rem; min-height: 80px; resize: vertical;"><%= post ? post.meta_description : '' %></textarea>
                                </div>
                            </div>

                            <!-- Governança de Exibição -->
                            <div style="margin-top: 30px; padding: 30px; background: white; border-radius: 24px; border: 1px solid #f0f0f0;">
                                <h4 style="margin: 0 0 20px; font-size: 0.8rem; letter-spacing: 1px; color: #0A1128; text-transform: uppercase; display: flex; align-items: center; gap: 10px;">
                                    <i class="ri-settings-4-line"></i> Controle de Visibilidade
                                </h4>
                                <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 25px;">
                                    <div class="form-group" style="display: flex; align-items: center; gap: 10px;">
                                        <input type="hidden" name="destaque_home" value="0">
                                        <input type="checkbox" name="destaque_home" value="1" <%= post && post.destaque_home ? 'checked' : '' %> style="width: 20px; height: 20px; accent-color: #0A1128;">
                                        <label style="font-weight: 700; font-size: 0.85rem; color: #444; margin: 0;">Destaque na Home?</label>
                                    </div>
                                    <div class="form-group" style="display: flex; align-items: center; gap: 10px;">
                                        <input type="hidden" name="ativo" value="0">
                                        <input type="checkbox" name="ativo" value="1" <%= !post || post.ativo ? 'checked' : '' %> style="width: 20px; height: 20px; accent-color: #0A1128;">
                                        <label style="font-weight: 700; font-size: 0.85rem; color: #444; margin: 0;">Artigo Ativo?</label>
                                    </div>
                                    <div class="form-group">
                                        <label style="display: block; font-weight: 800; font-size: 0.7rem; color: #666; margin-bottom: 5px; text-transform: uppercase;">Prioridade</label>
                                        <input type="number" name="ordem" value="<%= post ? post.ordem : 0 %>" style="width: 100%; padding: 10px; border: 1px solid #eee; border-radius: 8px;">
                                    </div>
                                </div>
                            </div>

                            <button type="submit" class="btn-premium" style="width: 100%; margin-top: 40px; background: #0A1128; color: white; border: none; padding: 18px; border-radius: 50px; font-weight: 900; letter-spacing: 1px; cursor: pointer; display: flex; justify-content: center; align-items: center; gap: 10px; transition: 0.3s;">
                                <i class="ri-save-3-line"></i> <%= post ? 'SALVAR ALTERAÇÕES' : 'PUBLICAR AGORA NO BLOG' %>
                            </button>
                        </form>
                    </div>
                    <%- include('../partials/admin-footer') %>
                </div>
            </div>
        </div>
    </div>

    <!-- Quill JS -->
    <script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
    <script>
        // Inicializar Quill
        var quill = new Quill('#quill-editor', {
            theme: 'snow',
            placeholder: 'Escreva seu artigo aqui...',
            modules: {
                toolbar: [
                    [{ 'header': [1, 2, 3, false] }],
                    ['bold', 'italic', 'underline', 'strike'],
                    ['blockquote', 'code-block'],
                    [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                    [{ 'color': [] }, { 'background': [] }],
                    ['link', 'image'],
                    ['clean']
                ]
            }
        });

        // Sincronizar Quill com o campo oculto antes de enviar
        document.querySelector('form').onsubmit = function() {
            var content = document.querySelector('.ql-editor').innerHTML;
            document.getElementById('hiddenConteudo').value = content;
        };

        function generateSlug(text) {
            const slug = text.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[^\w ]+/g, '').replace(/ +/g, '-');
            document.getElementById('slugInput').value = slug;
        }

        // Preview da Imagem
        document.getElementById('fileInput').onchange = evt => {
            const [file] = document.getElementById('fileInput').files;
            if (file) {
                document.getElementById('imgPreview').src = URL.createObjectURL(file);
            }
        }
    </script>
</body>
</html>
