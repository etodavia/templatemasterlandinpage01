<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | <%= settings.site_name || 'Sistema' %></title>
    <link rel="stylesheet" href="/css/admin.css">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&display=swap" rel="stylesheet">
</head>
<body>
    <div class="admin-app">
        <%- include('../partials/admin-sidebar') %>
        
        <div class="admin-main">
            <%- include('../partials/admin-header') %>
            <div class="admin-content-scroll">
                <div style="padding: 2.5rem 4rem;">
                    <div class="card-cms">
                        <header style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 50px;">
                            <div>
                                <h1 style="font-size: 2.2rem; margin: 0;">Gestão de <em>Equipe</em></h1>
                                <p class="subtitle" style="color: #888; font-size: 0.95rem; margin-top: 5px;">Controle o capital humano e a autoridade exibida no site.</p>
                            </div>
                            <a href="/admin/equipe/novo" class="btn-premium" style="background: #0A1128; color: white; border: none; padding: 12px 25px; border-radius: 50px; text-decoration: none; font-weight: 800; font-size: 0.85rem; display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 15px rgba(10,17,40,0.2);"><i class="ri-user-add-line"></i> ADICIONAR MEMBRO</a>
                        </header>

                        <%- include('../partials/admin-alerts') %>

                        <div class="table-responsive">
                            <% if (equipe.length === 0) { %>
                                <div style="text-align: center; color: #aaa; padding: 80px; background: #f8fafc; border-radius: 20px; border: 2px dashed #eee;">
                                    Nenhum membro cadastrado na equipe.
                                </div>
                            <% } else { %>
                                <table>
                                    <thead>
                                        <tr>
                                            <th style="width: 80px;">Foto</th>
                                            <th>Nome do Consultor</th>
                                            <th>Cargo / Especialidade</th>
                                            <th style="width: 150px; text-align: right;">Ações</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% equipe.forEach(member => { %>
                                            <tr>
                                                <td><img src="<%= member.imagem %>" style="width: 50px; height: 50px; border-radius: 50%; object-fit: cover; border: 2px solid white; box-shadow: 0 5px 15px rgba(0,0,0,0.05);"></td>
                                                <td><strong style="color: var(--admin-marinho);"><%= member.nome %></strong></td>
                                                <td><span style="font-size: 0.85rem; color: #666;"><%= member.funcao %></span></td>
                                                <td style="text-align: right;">
                                                    <div style="display: flex; gap: 10px; justify-content: flex-end;">
                                                        <a href="/admin/equipe/editar/<%= member.id %>" class="btn-action" style="background: #f0f0f0; color: #333; width: 35px; height: 35px; border-radius: 50%; display: flex; align-items: center; justify-content: center; text-decoration: none;" title="Editar"><i class="ri-pencil-line"></i></a>
                                                        <form action="/admin/equipe/delete/<%= member.id %>" method="POST" style="display: inline;" onsubmit="return confirm('Excluir este membro da equipe?')">
                                                            <button type="submit" class="btn-action" style="background: #fff0f0; color: #d62828; width: 35px; height: 35px; border-radius: 50%; display: flex; align-items: center; justify-content: center; border: none; cursor: pointer;" title="Remover"><i class="ri-delete-bin-line"></i></button>
                                                        </form>
                                                    </div>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    </tbody>
                                </table>
                            <% } %>
                        </div>
                    </div>
                </div>
                <%- include('../partials/admin-footer') %>
            </div>
        </div>
    </div>
</body>
</html>
