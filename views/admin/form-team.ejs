<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | <%= settings.site_name || 'Sistema' %></title>
    <link rel="stylesheet" href="/css/admin.css">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&display=swap" rel="stylesheet">
</head>
<body>
    <div class="admin-app">
        <%- include('../partials/admin-sidebar') %>
        
        <div class="admin-main">
            <%- include('../partials/admin-header') %>
            
            <div class="admin-content-scroll">
                <div style="padding: 2.5rem 4rem;">
                    <div style="max-width: 800px; margin: 0 auto; background: white; padding: 40px; border-radius: 30px; border: 1px solid #f0f0f0; box-shadow: 0 15px 40px rgba(0,0,0,0.02);">
                        <header style="margin-bottom: 40px; display: flex; justify-content: space-between; align-items: center;">
                            <div>
                                <h2 style="font-size: 2rem; color: #0A1128; margin: 0;"><%= member ? 'Refinar' : 'Integrar' %> <em>Membro</em></h2>
                            </div>
                            <a href="/admin/equipe" style="text-decoration: none; color: #666; font-weight: 700; font-size: 0.8rem; display: flex; align-items: center; gap: 5px;">
                                <i class="ri-arrow-left-line"></i> VOLTAR
                            </a>
                        </header>

                        <form action="<%= member ? '/admin/equipe/editar/' + member.id : '/admin/equipe' %>" method="POST" enctype="multipart/form-data">
                            <div style="text-align: center; margin-bottom: 40px; background: #F8FAFC; padding: 40px; border-radius: 24px; border: 1px dashed #ddd;">
                                <img id="imgPreview" src="<%= member ? member.imagem : '/img/placeholder-user.png' %>" 
                                     style="width: 150px; height: 150px; border-radius: 50%; object-fit: cover; border: 5px solid white; box-shadow: 0 10px 25px rgba(0,0,0,0.05); margin-bottom: 20px;">
                                
                                <input type="file" name="imagem_file" id="fileInput" accept="image/*" style="display: none;">
                                <button type="button" onclick="document.getElementById('fileInput').click()" 
                                        style="display: block; width: 220px; margin: 0 auto; background: #0A1128; color: white; border: none; padding: 12px; border-radius: 50px; font-size: 0.7rem; font-weight: 900; cursor: pointer; text-transform: uppercase; letter-spacing: 1px; transition: 0.3s;">
                                    <i class="ri-camera-lens-line"></i> ALTERAR FOTOGRAFIA
                                </button>
                                <input type="hidden" name="imagem" value="<%= member ? member.imagem : '' %>">
                            </div>

                            <div style="display: grid; grid-template-columns: 1fr; gap: 25px;">
                                <div class="form-group">
                                    <label style="display: block; font-weight: 800; font-size: 0.75rem; color: #666; margin-bottom: 10px; text-transform: uppercase;">Nome Completo do Consultor</label>
                                    <input type="text" name="nome" value="<%= member ? member.nome : '' %>" required placeholder="Ex: Dr. Marcus Albuquerque" style="width: 100%; padding: 15px; border: 1px solid #eee; border-radius: 12px; font-size: 1rem;">
                                </div>

                                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 25px;">
                                    <div class="form-group">
                                        <label style="display: block; font-weight: 800; font-size: 0.75rem; color: #666; margin-bottom: 10px; text-transform: uppercase;">Função / Cargo Estratégico</label>
                                        <input type="text" name="funcao" value="<%= member ? member.funcao : '' %>" required placeholder="Ex: Sócio Diretor & Estrategista" style="width: 100%; padding: 15px; border: 1px solid #eee; border-radius: 12px; font-size: 1rem;">
                                    </div>

                                    <div class="form-group">
                                        <label style="display: block; font-weight: 800; font-size: 0.75rem; color: #666; margin-bottom: 10px; text-transform: uppercase;">Ordem de Prioridade</label>
                                        <input type="number" name="ordem" value="<%= member ? member.ordem : 0 %>" placeholder="0" style="width: 100%; padding: 15px; border: 1px solid #eee; border-radius: 12px; font-size: 1rem;">
                                    </div>
                                </div>
                            </div>

                            <button type="submit" class="btn-premium" style="width: 100%; margin-top: 40px; background: #0A1128; color: white; border: none; padding: 18px; border-radius: 50px; font-weight: 900; letter-spacing: 1px; cursor: pointer; display: flex; justify-content: center; align-items: center; gap: 10px; transition: 0.3s;">
                                <i class="ri-save-3-line"></i> <%= member ? 'SALVAR ALTERAÇÕES' : 'INTEGRAR À EQUIPE' %>
                            </button>
                        </form>
                    </div>
                    <%- include('../partials/admin-footer') %>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.getElementById('fileInput').onchange = function (evt) {
            const [file] = evt.target.files;
            if (file) {
                document.getElementById('imgPreview').src = URL.createObjectURL(file);
            }
        }
    </script>
</body>
</html>
