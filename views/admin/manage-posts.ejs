<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | <%= settings.site_name || 'Sistema' %></title>
    <link rel="stylesheet" href="/css/admin.css">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&display=swap" rel="stylesheet">
</head>
<body>
    <div class="admin-app">
        <%- include('../partials/admin-sidebar') %>
        
        <div class="admin-main">
            <%- include('../partials/admin-header') %>
            <div class="admin-content-scroll">
                <div style="padding: 2.5rem 4rem;">
                    <div class="card-cms">
                        <header style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 50px;">
                            <div>
                                <h1 style="font-size: 2.2rem; margin: 0;">Gestão de <em>Artigos</em></h1>
                                <p class="subtitle" style="color: #888; font-size: 0.95rem; margin-top: 5px;">Controle total sobre o conteúdo e autoridade do blog.</p>
                            </div>
                            <a href="/admin/posts/novo" class="btn-premium" style="background: #0A1128; color: white; border: none; padding: 12px 25px; border-radius: 50px; text-decoration: none; font-weight: 800; font-size: 0.85rem; display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 15px rgba(10,17,40,0.2);"><i class="ri-add-line"></i> NOVO ARTIGO</a>
                        </header>

                        <%- include('../partials/admin-alerts') %>

                        <div class="table-responsive">
                            <% if (posts.length === 0) { %>
                                <div style="text-align: center; color: #aaa; padding: 80px; background: #f8fafc; border-radius: 20px; border: 2px dashed #eee;">
                                    Nenhum artigo publicado ainda.
                                </div>
                            <% } else { %>
                                <table>
                                    <thead>
                                        <tr>
                                            <th style="width: 100px;">Capa</th>
                                            <th>Título do Artigo</th>
                                            <th>Categoria</th>
                                            <th>Data</th>
                                            <th style="width: 150px; text-align: right;">Ações</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% posts.forEach(p => { %>
                                            <tr>
                                                <td>
                                                    <img src="<%= p.imagem %>" style="width: 80px; height: 50px; border-radius: 12px; object-fit: cover; border: 1px solid #eee;">
                                                </td>
                                                <td>
                                                    <strong style="color: var(--admin-marinho); display: block; max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><%= p.titulo %></strong>
                                                    <% if (p.destaque_home) { %>
                                                        <span style="font-size: 0.65rem; background: #FFF3E0; color: #E65100; padding: 2px 6px; border-radius: 4px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px;">Destaque Home</span>
                                                    <% } %>
                                                </td>
                                                <td><span style="font-size: 0.85rem; background: #F1F5F9; color: #475569; padding: 4px 10px; border-radius: 6px;"><%= p.categoria %></span></td>
                                                <td style="font-size: 0.85rem; color: #666;"><%= p.created_at.toLocaleDateString('pt-BR') %></td>
                                                <td style="text-align: right;">
                                                    <div style="display: flex; gap: 10px; justify-content: flex-end;">
                                                        <a href="/blog/<%= p.slug %>" target="_blank" class="btn-action" style="background: #e0f2fe; color: #0284c7; width: 35px; height: 35px; border-radius: 50%; display: flex; align-items: center; justify-content: center; text-decoration: none;" title="Ver no Site"><i class="ri-eye-line"></i></a>
                                                        <a href="/admin/posts/editar/<%= p.id %>" class="btn-action" style="background: #fef3c7; color: #d97706; width: 35px; height: 35px; border-radius: 50%; display: flex; align-items: center; justify-content: center; text-decoration: none;" title="Editar"><i class="ri-pencil-line"></i></a>
                                                        <form action="/admin/posts/delete/<%= p.id %>" method="POST" style="display: inline;" onsubmit="return confirm('Excluir este artigo permanentemente?')">
                                                            <button type="submit" class="btn-action" style="background: #fff1f2; color: #e11d48; border: none; width: 35px; height: 35px; border-radius: 50%; cursor: pointer;" title="Remover"><i class="ri-delete-bin-line"></i></button>
                                                        </form>
                                                    </div>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    </tbody>
                                </table>
                            <% } %>
                        </div>
                    </div>
                </div>
                <%- include('../partials/admin-footer') %>
            </div>
        </div>
    </div>
</body>
</html>
