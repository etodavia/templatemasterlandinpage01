<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | <%= settings.site_name || 'Sistema' %></title>
    <link rel="stylesheet" href="/css/admin.css">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&display=swap" rel="stylesheet">
</head>
<body>
    <div class="admin-app">
        <%- include('../partials/admin-sidebar') %>
        
        <div class="admin-main">
            <%- include('../partials/admin-header') %>
            <div class="admin-content-scroll">
                <div style="padding: 2.5rem 4rem;">
                    <header style="margin-bottom: 40px;">
                        <h1 style="font-size: 2.2rem; margin: 0;">Moderação de <em>Comentários</em></h1>
                        <p style="color: #888; font-size: 0.95rem; margin-top: 5px;">Gerencie as interações dos leitores nos artigos do blog.</p>
                    </header>

                    <div class="comments-list">
                        <% if (comentarios.length === 0) { %>
                            <div style="text-align: center; padding: 80px; background: white; border-radius: 30px; border: 1px solid #f0f0f0; color: #aaa;">
                                <i class="ri-chat-4-line" style="font-size: 3rem; display: block; margin-bottom: 15px; opacity: 0.2;"></i>
                                <p>Nenhum comentário enviado ainda.</p>
                            </div>
                        <% } else { %>
                            <div style="display: grid; gap: 20px;">
                                <% comentarios.forEach(c => { %>
                                    <div style="background: white; padding: 25px; border-radius: 20px; border: 1px solid #f0f0f0; display: flex; justify-content: space-between; align-items: flex-start; gap: 20px;">
                                        <div style="flex: 1;">
                                            <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 10px;">
                                                <h4 style="margin: 0; color: var(--admin-marinho);"><%= c.nome %></h4>
                                                <span style="font-size: 0.7rem; color: #aaa;"><%= c.email %></span>
                                                <span style="font-size: 0.7rem; color: #666; background: #f8fafc; padding: 2px 8px; border-radius: 4px;">ID Post: <%= c.post_id %></span>
                                            </div>
                                            <p style="margin: 0; color: #444; font-size: 0.9rem; line-height: 1.5;"><%= c.comentario %></p>
                                            <div style="margin-top: 15px;">
                                                <span style="font-size: 0.7rem; color: <%= c.aprovado ? '#10b981' : '#f59e0b' %>; font-weight: 800; text-transform: uppercase; letter-spacing: 1px;">
                                                    <%= c.aprovado ? '✓ PUBLICADO' : '● AGUARDANDO APROVAÇÃO' %>
                                                </span>
                                            </div>
                                        </div>
                                        <div style="display: flex; gap: 8px;">
                                            <% if (!c.aprovado) { %>
                                                <form action="/admin/comentarios/aprovar/<%= c.id %>" method="POST" style="display: inline;">
                                                    <button type="submit" class="btn-action" style="background: #ecfdf5; color: #10b981; border: none; padding: 8px 15px; border-radius: 12px; font-size: 0.7rem; font-weight: 800; cursor: pointer;">APROVAR</button>
                                                </form>
                                            <% } %>
                                            <form action="/admin/comentarios/delete/<%= c.id %>" method="POST" style="display: inline;" onsubmit="return confirm('Excluir comentário permanentemente?')">
                                                <button type="submit" class="btn-action" style="background: #fff1f2; color: #e11d48; border: none; padding: 8px 12px; border-radius: 12px; font-size: 0.7rem; font-weight: 800; cursor: pointer;"><i class="ri-delete-bin-line"></i></button>
                                            </form>
                                        </div>
                                    </div>
                                <% }) %>
                            </div>
                        <% } %>
                    </div>
                </div>
                <%- include('../partials/admin-footer') %>
            </div>
        </div>
    </div>
</body>
</html>
