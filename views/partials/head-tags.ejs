<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<%
    const siteName = settings.site_name || 'Sua Empresa';
    const metaTitle = title || settings.meta_title_home || siteName;
    const metaDescription = locals.description || settings.meta_description_home || `Conheça os serviços da ${siteName} e solicite um orçamento.`;
    const rawShareImage = locals.ogImage || settings.seo_share_image || settings.hero_image || settings.logo || settings.favicon || '/capashow1.png';
    const shareImage = locals.absoluteAssetUrl ? locals.absoluteAssetUrl(rawShareImage) : rawShareImage;
    const pageUrl = locals.canonicalUrl || locals.currentUrl || '';
    const robotsContent = (locals.isAdminPage || locals.isNotFoundPage) ? 'noindex, nofollow, noarchive' : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1';
    let configuredSocialProfiles = [];
    try {
        configuredSocialProfiles = JSON.parse(settings.social_links || '[]').map((item) => item.url).filter(Boolean);
    } catch (error) {
        configuredSocialProfiles = [];
    }
    const socialProfiles = [...new Set([
        settings.instagram_url,
        settings.facebook_url,
        settings.linkedin_url,
        ...configuredSocialProfiles
    ].filter(Boolean))];
    const businessAddress = settings.address_full || settings.endereco;
    const validTaxId = settings.cnpj && settings.cnpj !== '00.000.000/0001-00' ? settings.cnpj : undefined;
    const businessSchema = {
        '@context': 'https://schema.org',
        '@type': businessAddress ? 'MovingCompany' : 'Organization',
        '@id': `${locals.baseUrl || ''}/#organization`,
        name: siteName,
        url: locals.baseUrl || pageUrl,
        description: metaDescription,
        image: shareImage || undefined,
        logo: settings.logo && locals.absoluteAssetUrl ? locals.absoluteAssetUrl(settings.logo) : undefined,
        telephone: settings.contact_phone || settings.whatsapp || undefined,
        email: settings.contact_email || undefined,
        taxID: validTaxId,
        address: businessAddress ? {
            '@type': 'PostalAddress',
            streetAddress: businessAddress,
            addressCountry: 'BR'
        } : undefined,
        sameAs: socialProfiles.length ? socialProfiles : undefined
    };
    const webSiteSchema = {
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        '@id': `${locals.baseUrl || ''}/#website`,
        url: locals.baseUrl || pageUrl,
        name: siteName,
        publisher: { '@id': `${locals.baseUrl || ''}/#organization` },
        inLanguage: 'pt-BR'
    };
    const webPageSchema = {
        '@context': 'https://schema.org',
        '@type': locals.article ? 'BlogPosting' : 'WebPage',
        '@id': `${pageUrl}#webpage`,
        url: pageUrl,
        name: metaTitle,
        description: metaDescription,
        isPartOf: { '@id': `${locals.baseUrl || ''}/#website` },
        about: { '@id': `${locals.baseUrl || ''}/#organization` },
        primaryImageOfPage: shareImage ? { '@type': 'ImageObject', url: shareImage } : undefined,
        headline: locals.article ? (locals.article.titulo || metaTitle) : undefined,
        datePublished: locals.article ? (locals.article.created_at || undefined) : undefined,
        image: locals.article && shareImage ? shareImage : undefined,
        author: locals.article ? { '@id': `${locals.baseUrl || ''}/#organization` } : undefined,
        publisher: locals.article ? { '@id': `${locals.baseUrl || ''}/#organization` } : undefined,
        mainEntityOfPage: locals.article ? pageUrl : undefined,
        inLanguage: 'pt-BR'
    };
    const safeJson = (data) => JSON.stringify(data).replace(/</g, '\\u003c');
%>
<title><%= metaTitle %></title>
<meta name="description" content="<%= metaDescription %>">
<meta name="robots" content="<%= robotsContent %>">
<meta name="googlebot" content="<%= robotsContent %>">
<% if (locals.keywords) { %><meta name="keywords" content="<%= locals.keywords %>"><% } %>
<% if (pageUrl) { %><link rel="canonical" href="<%= pageUrl %>"><% } %>
<% if (settings.favicon) { %>
<link rel="icon" type="image/x-icon" href="<%= settings.favicon %>">
<% } %>

<!-- SEO & Social Meta -->
<meta property="og:title" content="<%= metaTitle %>">
<meta property="og:description" content="<%= metaDescription %>">
<meta property="og:type" content="<%= locals.article ? 'article' : 'website' %>">
<% if (pageUrl) { %><meta property="og:url" content="<%= pageUrl %>"><% } %>
<meta property="og:site_name" content="<%= settings.site_name || metaTitle %>">
<meta property="og:locale" content="pt_BR">
<% if (shareImage) { %>
<meta property="og:image" content="<%= shareImage %>">
<meta property="og:image:secure_url" content="<%= shareImage %>">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:image:alt" content="<%= metaTitle %>">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="<%= metaTitle %>">
<meta name="twitter:description" content="<%= metaDescription %>">
<meta name="twitter:image" content="<%= shareImage %>">
<% } %>

<% if (!locals.isAdminPage && !locals.isNotFoundPage) { %>
<script type="application/ld+json"><%- safeJson(businessSchema) %></script>
<script type="application/ld+json"><%- safeJson(webSiteSchema) %></script>
<script type="application/ld+json"><%- safeJson(webPageSchema) %></script>
<% } %>

<% 
    const fontTitleVal = settings.font_title || 'Playfair Display';
    const fontBodyVal = settings.font_body || 'Inter Tight';
    function remVar(value, fallback) {
        const parsed = parseFloat(value);
        return Number.isFinite(parsed) && parsed > 0 ? parsed.toFixed(2) + 'rem' : fallback + 'rem';
    }
    const fontsList = [];
    if (fontTitleVal) fontsList.push(`family=${fontTitleVal.replace(/ /g, '+')}:ital,wght@1,400;1,700`);
    if (fontBodyVal) fontsList.push(`family=${fontBodyVal.replace(/ /g, '+')}:wght@400;600;700;800`);
    const fontsQuery = fontsList.join('&');
%>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin>
<link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
<link href="https://fonts.googleapis.com/css2?<%= fontsQuery %>&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/main.min.css?v=<%= locals.assetVersion || '1' %>">
<style>
    :root {
        --navy-blue: <%= settings.color_marinho || '#0A1128' %>;
        --bg-sand: <%= settings.color_areia || '#F7F7F4' %>;
        --accent-red: <%= settings.color_vermelho || '#D62828' %>;
        --text-color: <%= settings.color_texto || '#333333' %>;
        --bg-header: <%= settings.color_header || '#FFFFFF' %>;
        --bg-footer: <%= settings.color_footer || '#0A1128' %>;
        --text-header: <%= settings.color_header_text || settings.color_texto || '#333333' %>;
        --text-footer: <%= settings.color_footer_text || '#FFFFFF' %>;

        /* Fontes Dinâmicas */
        --font-serif: '<%= fontTitleVal %>', serif;
        --font-main: '<%= fontBodyVal %>', sans-serif;
        --title-hero-size: <%= remVar(settings.title_size_hero_desktop, 4) %>;
        --title-page-size: <%= remVar(settings.title_size_page_desktop, 3.2) %>;
        --title-section-size: <%= remVar(settings.title_size_section_desktop, 3) %>;
        --title-card-size: <%= remVar(settings.title_size_card_desktop, 1.5) %>;

        /* Cores de Seções e Páginas */
        --bg-about: <%= settings.color_about_bg || settings.color_areia || '#F7F7F4' %>;
        --bg-blog: <%= settings.color_blog_bg || settings.color_marinho || '#0A1128' %>;
        --text-blog: <%= settings.color_blog_text || '#FFFFFF' %>;
        --bg-contact: <%= settings.color_contact_bg || settings.color_areia || '#F7F7F4' %>;
    }

    body {
        margin: 0;
        padding: 0;
        font-family: var(--font-main);
    }

    @media (max-width: 1024px) {
        :root {
            --title-hero-size: <%= remVar(settings.title_size_hero_tablet, 3.1) %>;
            --title-page-size: <%= remVar(settings.title_size_page_tablet, 2.8) %>;
            --title-section-size: <%= remVar(settings.title_size_section_tablet, 2.5) %>;
            --title-card-size: <%= remVar(settings.title_size_card_tablet, 1.35) %>;
        }
    }

    @media (max-width: 640px) {
        :root {
            --title-hero-size: <%= remVar(settings.title_size_hero_mobile, 2.2) %>;
            --title-page-size: <%= remVar(settings.title_size_page_mobile, 2.3) %>;
            --title-section-size: <%= remVar(settings.title_size_section_mobile, 2.1) %>;
            --title-card-size: <%= remVar(settings.title_size_card_mobile, 1.2) %>;
        }
    }
</style>
<link href="https://cdn.jsdelivr.net/npm/remixicon@4.5.0/fonts/remixicon.css" rel="stylesheet">
<script defer src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
<script defer src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
<script defer src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<!-- Google Analytics -->
<% if (settings.google_analytics) { %>
<script async src="https://www.googletagmanager.com/gtag/js?id=<%= settings.google_analytics %>"></script>
<script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', '<%= settings.google_analytics %>');
</script>
<% } %>

<!-- Facebook Pixel -->
<% if (settings.facebook_pixel) { %>
<script>
    !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?
    n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;
    n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;
    t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,
    document,'script','https://connect.facebook.net/en_US/fbevents.js');
    fbq('init', '<%= settings.facebook_pixel %>');
    fbq('track', 'PageView');
</script>
<% } %>

<!-- Pinterest Tag -->
<% if (settings.pinterest_pixel) { %>
<script>
    !function(e){if(!window.pintrk){window.pintrk=function(){window.pintrk.queue.push(Array.prototype.slice.call(arguments))};var n=window.pintrk;n.queue=[],n.push=e;var t=document.createElement("script");t.async=!0,t.src="https://s.pinimg.com/ct/lib/main.js";var r=document.getElementsByTagName("script")[0];r.parentNode.insertBefore(t,r)}}("<%= settings.pinterest_pixel %>");
    pintrk('load', '<%= settings.pinterest_pixel %>');
    pintrk('page');
</script>
<% } %>

<!-- LinkedIn Tag -->
<% if (settings.linkedin_pixel) { %>
<script type="text/javascript">
    _linkedin_partner_id = "<%= settings.linkedin_pixel %>";
    window._linkedin_data_partner_ids = window._linkedin_data_partner_ids || [];
    window._linkedin_data_partner_ids.push(_linkedin_partner_id);
</script>
<script type="text/javascript">
    (function(l) {
    if (!l){window.lintrk = function(a,b){window.lintrk.q.push([a,b])};
    window.lintrk.q=[]}
    var s = document.getElementsByTagName("script")[0];
    var b = document.createElement("script");
    b.type = "text/javascript";b.async = true;
    b.src = "https://snap.licdn.com/li.lms-analytics/insight.min.js";
    s.parentNode.insertBefore(b, s);})(window.lintrk);
</script>
<% } %>

<!-- Custom Head Code Injection -->
<%- settings.custom_head_code || '' %>
