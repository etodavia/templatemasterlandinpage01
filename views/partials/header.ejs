<% if (locals.licenseStatus === 'grace') { %>
    <div class="license-banner grace" style="background: #E65100; color: white; padding: 12px 20px; font-size: 0.85rem; font-weight: 700; text-align: center; display: flex; align-items: center; justify-content: center; gap: 8px; z-index: 99999; position: relative; font-family: 'Inter', sans-serif; box-shadow: 0 4px 10px rgba(0,0,0,0.1);">
        <i class="ri-error-warning-line" style="font-size: 1.1rem;"></i>
        <span>⚠️ AVISO DE MANUTENÇÃO: A licença anual da plataforma expirou há <%= locals.daysOverdue %> dias. Regularize no painel para evitar suspensão (Carência: <%= locals.daysOverdue %>/30 dias).</span>
    </div>
<% } else if (locals.licenseStatus === 'expired') { %>
    <div class="license-banner expired" style="background: #D62828; color: white; padding: 16px 20px; font-size: 0.9rem; font-weight: 800; text-align: center; display: flex; align-items: center; justify-content: center; gap: 10px; z-index: 999999; position: fixed; top: 0; left: 0; width: 100%; font-family: 'Inter', sans-serif; box-shadow: 0 5px 25px rgba(214,40,40,0.4); text-transform: uppercase; letter-spacing: 0.5px;">
        <i class="ri-spam-3-line" style="font-size: 1.3rem; animation: pulse 1s infinite alternate;"></i>
        <span>🚨 PLATAFORMA SUSPENSA: A licença anual deste website expirou há <%= locals.daysOverdue %> dias. Regularize no Painel Administrativo e pague a renovação para restabelecer o site.</span>
    </div>
    <style>
        body { margin-top: 55px !important; }
        @media (max-width: 768px) {
            body { margin-top: 75px !important; }
            .license-banner.expired { font-size: 0.75rem; padding: 12px; }
        }
        @keyframes pulse {
            from { transform: scale(1); }
            to { transform: scale(1.15); }
        }
    </style>
<% } %>

<div class="header-wrapper">
    <% if (settings.show_topbar == 1) { %>
    <div class="topbar" style="background: var(--navy-blue); color: white; padding: 10px 0; font-size: 0.75rem;">
        <div class="container" style="display: flex; justify-content: space-between; align-items: center;">
            <div class="topbar-left">
                <span><i class="ri-map-pin-line"></i> <%= settings.endereco %></span>
            </div>
            <% if (settings.header_strip_text) { %>
            <div class="topbar-center" style="font-weight: 700; letter-spacing: 0.5px;">
                <%= settings.header_strip_text %>
            </div>
            <% } %>
            <div class="topbar-right" style="display: flex; gap: 15px;">
                <% 
                    const socialIconsMap = {
                        instagram: 'ri-instagram-line', facebook: 'ri-facebook-fill', linkedin: 'ri-linkedin-fill', 
                        youtube: 'ri-youtube-fill', tiktok: 'ri-tiktok-fill', twitter: 'ri-twitter-x-fill', 
                        pinterest: 'ri-pinterest-fill', google: 'ri-google-fill'
                    };
                    let socialLinksHeader = [];
                    try { socialLinksHeader = JSON.parse(settings.social_links || '[]'); } catch(e) { socialLinksHeader = []; }
                %>
                <% socialLinksHeader.forEach(item => { %>
                    <% if (item.network && item.url && socialIconsMap[item.network]) { %>
                        <a href="<%= item.url %>" target="_blank" style="color: white; text-decoration: none;"><i class="<%= socialIconsMap[item.network] %>"></i></a>
                    <% } %>
                <% }) %>
            </div>
        </div>
    </div>
    <% } %>

    <header>
        <a href="/" class="logo">
            <% if (settings.logo) { %>
                <img src="<%= settings.logo %>" alt="<%= settings.site_name || 'Empresa' %>" class="logo-main" style="max-height: 40px;">
                <% if (settings.logo_white) { %>
                    <img src="<%= settings.logo_white %>" alt="<%= settings.site_name || 'Empresa' %>" class="logo-white" style="display: none; max-height: 40px;">
                <% } %>
            <% } else { %>
                Sistema
            <% } %>
        </a>
        <nav>
            <ul class="desktop-menu">
                <% 
                   let menu = [
                       { label: 'Home', link: '/#home' },
                       { label: 'Sobre', link: '/#sobre' },
                       { label: 'Serviços', link: '/#servicos' },
                       { label: 'Contato', link: '/#contato' }
                   ];
                   if (settings.site_menu && settings.site_menu.trim() !== '') {
                       menu = settings.site_menu.split('\n').filter(line => line.includes('|')).map(line => {
                           const [label, link] = line.split('|');
                           return { label: label.trim(), link: link.trim() };
                       });
                   }
                %>
                <% menu.forEach(item => { 
                    const isActive = (locals.currentPage === item.label.toLowerCase()) || 
                                   (locals.currentPage === 'home' && item.link === '/') ||
                                   (item.link !== '/' && locals.currentPage === item.link.replace('/', ''));
                %>
                    <li>
                        <a href="<%= item.link %>" class="menu-item-link <%= isActive ? 'active' : '' %>">
                            <div class="roll-btn">
                                <span class="roll-text"><%= item.label %></span>
                                <span class="roll-text"><%= item.label %></span>
                            </div>
                        </a>
                    </li>
                <% }); %>
            </ul>
        </nav>
        
        <!-- MOBILE/TABLET QUICK ICONS (ENTRE LOGO E BOTÃO) -->
        <div class="header-mobile-icons">
            <a href="/" class="m-icon-link" title="Home"><i class="ri-home-4-fill"></i></a>
            <a href="/admin/login" class="m-icon-link" title="Login"><i class="ri-user-settings-fill"></i></a>
        </div>

        <div class="header-right">
            <a href="/admin/login" class="login-link menu-item-link desktop-only">
                <div class="roll-btn">
                    <span class="roll-text">Login <i class="ri-login-box-line"></i></span>
                    <span class="roll-text">Login <i class="ri-login-box-line"></i></span>
                </div>
            </a>
            <% if (settings.whatsapp) { %>
            <a href="https://wa.me/<%= settings.whatsapp %>?text=<%= encodeURIComponent(settings.whatsapp_message || 'Olá, estive no site e gostaria de agendar uma consulta.') %>" class="btn-cta-header btn-whatsapp-conversion" target="_blank">
                <%= settings.nav_cta_text || 'Agendar Consulta' %>
            </a>
            <% } %>
        </div>
    </header>
</div>

<!-- SCRIPT GSAP PARA EFEITO ROLLING -->
<script>
    document.addEventListener("DOMContentLoaded", () => {
        if (!window.gsap) return;
        gsap.utils.toArray(".menu-item-link").forEach(link => {
            const roll = link.querySelector(".roll-btn");
            if (!roll) return;
            link.addEventListener("mouseenter", () => {
                gsap.to(roll, { yPercent: -50, duration: 0.3, ease: "power2.out" });
            });
            link.addEventListener("mouseleave", () => {
                gsap.to(roll, { yPercent: 0, duration: 0.3, ease: "power2.in" });
            });
        });
    });
</script>
