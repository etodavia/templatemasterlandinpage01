<section class="page-hero" style="background: linear-gradient(rgba(10, 17, 40, 0.4), rgba(10, 17, 40, 0.8)), url('<%= locals.image || "/img/hero_optimo.png" %>') center/cover;">
    <div class="container">
        <div class="page-hero-content">
            <span class="section-label" data-reveal style="color: white; opacity: 0.6;">Consultoria Boutique Sistema</span>
            <h1 data-reveal style="color: white;">
                <% if (pageTitle.includes('<em>')) { %>
                    <%- pageTitle %>
                <% } else { %>
                    <% 
                        const words = pageTitle.split(' ');
                        if (words.length > 1) {
                            const lastWord = words.pop();
                            const rest = words.join(' ');
                    %>
                        <%= rest %> <em><%= lastWord %></em>
                    <% } else { %>
                        <%= pageTitle %>
                    <% } %>
                <% } %>
            </h1>
        </div>
    </div>
</section>
